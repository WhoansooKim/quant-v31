    // Step Actions
    // ════════════════════════════════

    private async Task RefreshUniverse()
    {
        runningStep = "universe";
        statusMsg = null;
        var token = _cts.Token;
        try
        {
            var beforeCount = universeCount;
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/universe/refresh", null);
            if (resp.IsSuccessStatusCode)
            {
                statusMsg = "Universe refresh started...";
                StateHasChanged();
                for (int i = 0; i < 20; i++)
                {
                    try { await Task.Delay(3000, token); } catch (TaskCanceledException) { return; }
                    var newCount = await Db.GetUniverseCountAsync();
                    if (newCount != beforeCount || i >= 5)
                    {
                        statusMsg = $"Universe refreshed: {newCount} symbols";
                        break;
                    }
                }
            }
            else
            {
                statusMsg = $"Error: {resp.StatusCode}";
            }
        }
        catch (Exception ex) { statusMsg = $"Error: {ex.Message}"; }
        finally { runningStep = null; if (!token.IsCancellationRequested) await LoadAllData(); }
    }

    private async Task CollectData()
    {
        runningStep = "collect";
        statusMsg = null;
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/collect", null);
            if (resp.IsSuccessStatusCode)
            {
                statusMsg = "Data collection started...";
                await PollUntilDone("collect", 300);
            }
            else
            {
                statusMsg = $"Error: {resp.StatusCode}";
            }
        }
        catch (Exception ex) { statusMsg = $"Error: {ex.Message}"; }
        finally { runningStep = null; if (!_cts.IsCancellationRequested) await LoadAllData(); }
    }

    private async Task ScanSignals()
    {
        runningStep = "scan";
        statusMsg = null;
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/scan", null);
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                var entries = json.TryGetProperty("entries", out var e) ? e.GetInt32() : 0;
                var exits = json.TryGetProperty("exits", out var x) ? x.GetInt32() : 0;
                var elapsed = json.TryGetProperty("elapsed_sec", out var t) ? t.GetDouble() : 0;
                statusMsg = $"Scan complete ({elapsed:F1}s) — {entries} entry signals, {exits} exit signals";
            }
            else
            {
                statusMsg = $"Scan error: {resp.StatusCode}";
            }
        }
        catch (Exception ex) { statusMsg = $"Error: {ex.Message}"; }
        finally { runningStep = null; if (!_cts.IsCancellationRequested) await LoadAllData(); }
    }

    private async Task RunFullPipeline()
    {
        runningStep = "full";
        statusMsg = null;
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/pipeline/run", null);
            if (resp.IsSuccessStatusCode)
            {
                statusMsg = "Full pipeline started...";
                await PollUntilDone("full_pipeline", 300);
            }
            else
            {
                statusMsg = $"Error: {resp.StatusCode}";
            }
        }
        catch (Exception ex) { statusMsg = $"Error: {ex.Message}"; }
        finally { runningStep = null; if (!_cts.IsCancellationRequested) await LoadAllData(); }
    }

    private async Task PollUntilDone(string stepName, int maxSeconds)
    {
        var token = _cts.Token;
        for (int i = 0; i < maxSeconds / 3; i++)
        {
            try
            {
                await Task.Delay(3000, token);
            }
            catch (TaskCanceledException) { return; }

            if (token.IsCancellationRequested) return;

            try
            {
                logCurrentPage = 1;
                pipelineLogs = await Db.GetPipelineLogsAsync(0, LogPageSize);
                await InvokeAsync(StateHasChanged);
            }
            catch { continue; }

            // step의 completed/failed 로그 찾기 (최근 로그 중)
            var latest = pipelineLogs.FirstOrDefault(l =>
                l.StepName == stepName && (l.Status == "completed" || l.Status == "failed"));
            if (latest != null)
            {
                statusMsg = latest.Status == "completed"
                    ? $"{stepName} completed in {latest.ElapsedSec:F1}s"
                    : $"{stepName} failed: {latest.ErrorMsg}";
                return;
            }
        }
        statusMsg = $"{stepName}: polling timeout ({maxSeconds}s) — may still be running";
    }

