    private static string StatusCss(string status) => status switch
    {
        "completed" => "executed",
        "started" => "approved",
        "failed" => "rejected",
        _ => "pending"
    };

    private static string FormatMarketCap(decimal? cap)
    {
        if (cap == null) return "--";
        var v = (double)cap.Value;
        if (v >= 1_000_000_000_000) return $"{v / 1_000_000_000_000:F1}T";
        if (v >= 1_000_000_000) return $"{v / 1_000_000_000:F1}B";
        if (v >= 1_000_000) return $"{v / 1_000_000:F0}M";
        return $"{v:N0}";
    }
