@page "/positions"
@attribute [Authorize]
@inject SwingService Db
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Swing V4 - Positions</PageTitle>

<div class="page-header">
    <h3>Positions</h3>
</div>

<!-- Factor Crowding + Short Interest Panel -->
@if (crowdingLoaded && crowdingData.HasValue)
{
    var cd = crowdingData.Value;
    <div class="section-card" style="margin-bottom:0.75rem; padding:0.75rem">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.5rem">
            <h4 style="margin:0; font-size:0.9rem">
                <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">monitoring</span>
                Factor Crowding & Short Interest
            </h4>
            <button class="btn-sm" style="font-size:0.7rem; padding:2px 8px" @onclick="LoadCrowding" disabled="@crowdingLoading">
                @(crowdingLoading ? "..." : "Refresh")
            </button>
        </div>
        <!-- ETF Overlap Bars -->
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:0.4rem">
            @if (cd.TryGetProperty("crowding", out var cw) && cw.TryGetProperty("factors", out var factors))
            {
                @foreach (var etf in new[] { "momentum", "quality", "value", "low_vol", "growth" })
                {
                    if (factors.TryGetProperty(etf, out var f))
                    {
                        var pct = f.TryGetProperty("overlap_pct", out var op) ? op.GetDouble() * 100 : 0;
                        var risk = f.TryGetProperty("risk_level", out var rl) ? rl.GetString() : "low";
                        var etfName = f.TryGetProperty("etf", out var en) ? en.GetString() : etf.ToUpper();
                        var barColor = risk == "high" ? "#ef4444" : risk == "moderate" ? "#eab308" : "#22c55e";
                        <div>
                            <div style="display:flex; justify-content:space-between; font-size:0.72rem; margin-bottom:2px">
                                <span>@etfName <span class="text-muted">(@etf)</span></span>
                                <span style="color:@barColor; font-weight:600">@pct.ToString("F0")%</span>
                            </div>
                            <div style="height:6px; background:var(--bg-secondary); border-radius:3px; overflow:hidden">
                                <div style="width:@pct%; height:100%; background:@barColor; border-radius:3px; transition:width 0.3s"></div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
        <!-- Per-Symbol Detail -->
        @if (cd.TryGetProperty("per_symbol", out var perSym))
        {
            <div style="margin-top:0.5rem; display:flex; flex-wrap:wrap; gap:0.3rem">
                @foreach (var item in perSym.EnumerateArray())
                {
                    var sym = item.TryGetProperty("symbol", out var s) ? s.GetString() : "";
                    var risk = item.TryGetProperty("risk_level", out var r) ? r.GetString() : "low";
                    var factors2 = item.TryGetProperty("factor_count", out var fc) ? fc.GetInt32() : 0;
                    var badgeColor = risk == "high" ? "badge-red" : risk == "moderate" ? "badge-yellow" : "badge-green";
                    <span class="badge @badgeColor" style="font-size:0.7rem; padding:2px 6px" title="@sym: @factors2 factor ETF overlap">
                        @sym @(factors2 > 0 ? $"({factors2})" : "")
                    </span>
                }
            </div>
        }
        <!-- Short Interest -->
        @if (shortInterestData.Count > 0)
        {
            <div style="margin-top:0.5rem; border-top:1px solid var(--border); padding-top:0.4rem">
                <div style="font-size:0.75rem; font-weight:600; margin-bottom:0.3rem">Short Interest (Days to Cover)</div>
                <div style="display:flex; flex-wrap:wrap; gap:0.5rem; font-size:0.72rem">
                    @foreach (var kv in shortInterestData)
                    {
                        var sir = kv.Value;
                        var ratio = sir.TryGetProperty("short_ratio", out var sr) ? sr.GetDouble() : 0;
                        var changePct = sir.TryGetProperty("change_pct", out var cp) ? cp.GetDouble() : 0;
                        var sirColor = ratio > 10 ? "#ef4444" : ratio > 5 ? "#eab308" : "#22c55e";
                        <span style="display:inline-flex; align-items:center; gap:3px">
                            <b>@kv.Key</b>
                            <span style="color:@sirColor; font-weight:600">@ratio.ToString("F1")d</span>
                            @if (changePct != 0)
                            {
                                <span style="color:@(changePct < 0 ? "#22c55e" : "#ef4444"); font-size:0.65rem">
                                    @(changePct > 0 ? "+" : "")@changePct.ToString("F0")%
                                </span>
                            }
                        </span>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- Tabs -->
<div class="tab-bar">
    <button class="tab-btn @(showOpen ? "active" : "")" @onclick="SwitchToOpen">
        Open (@openTotalCount)
    </button>
    <button class="tab-btn @(!showOpen ? "active" : "")" @onclick="SwitchToClosed">
        Closed (@closedTotalCount)
    </button>
</div>

<div class="section-card" style="margin-top:0.5rem">
    @if (showOpen)
    {
        <!-- Open Positions -->
        @if (openPositions.Any())
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="sortable" @onclick='() => openSort.Toggle("symbol")'>Symbol@(openSort.Arrow("symbol"))</th>
                            <th>Side</th>
                            <th class="sortable" @onclick='() => openSort.Toggle("qty")'>Qty@(openSort.Arrow("qty"))</th>
                            <th class="sortable" @onclick='() => openSort.Toggle("entry")'>Entry@(openSort.Arrow("entry"))</th>
                            <th>Current</th>
                            <th class="sortable" @onclick='() => openSort.Toggle("pnl")'>P&L ($)@(openSort.Arrow("pnl"))</th>
                            <th class="sortable" @onclick='() => openSort.Toggle("pnlPct")'>P&L (%)@(openSort.Arrow("pnlPct"))</th>
                            <th>Stop Loss</th>
                            <th>Take Profit</th>
                            <th>Flags</th>
                            <th class="sortable" @onclick='() => openSort.Toggle("holdDays")'>Hold Days@(openSort.Arrow("holdDays"))</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in SortedOpen)
                        {
                            var pnlClass = (p.UnrealizedPct ?? 0) >= 0 ? "text-green" : "text-red";
                            var holdDays = (DateTime.Now - p.EntryTime).Days;
                            <tr>
                                <td><SymbolLink Symbol="@p.Symbol" OnSymbolClick="OpenModal" /></td>
                                <td>@p.Side</td>
                                <td>@p.Qty</td>
                                <td>$@p.EntryPrice.ToString("F2")</td>
                                <td>@(p.CurrentPrice != null ? $"${p.CurrentPrice:F2}" : "--")</td>
                                <td class="@pnlClass">
                                    @(p.UnrealizedPnl != null ? $"{(p.UnrealizedPnl >= 0 ? "+" : "")}${p.UnrealizedPnl:F2}" : "--")
                                </td>
                                <td class="@pnlClass">
                                    @(p.UnrealizedPct != null ? $"{(p.UnrealizedPct >= 0 ? "+" : "")}{p.UnrealizedPct * 100:F2}%" : "--")
                                </td>
                                <td class="text-red">
                                    @(p.StopLoss != null ? $"${p.StopLoss:F2}" : "--")
                                    @if (p.TrailingStopActive)
                                    {
                                        <span class="badge badge-trail" title="Trailing Stop Active (HWM: $@(p.HighWaterMark?.ToString("F2") ?? "--"))">TRAIL</span>
                                    }
                                </td>
                                <td class="text-green">@(p.TakeProfit != null ? $"${p.TakeProfit:F2}" : "--")</td>
                                <td>
                                    @if (p.TrailingStopActive)
                                    {
                                        <span class="exit-flag flag-trail" title="Trailing stop active">
                                            <span class="material-symbols-outlined" style="font-size:14px">trending_up</span>
                                        </span>
                                    }
                                    @if (p.PartialExited)
                                    {
                                        <span class="exit-flag flag-partial" title="Partial exit executed (50%)">
                                            <span class="material-symbols-outlined" style="font-size:14px">pie_chart</span>
                                        </span>
                                    }
                                </td>
                                <td>@holdDays</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Pagination -->
            @if (openTotalPages > 1)
            {
                <div class="pagination-bar">
                    <button class="btn-page" disabled="@(openCurrentPage <= 1)" @onclick="() => GoToOpenPage(1)">«</button>
                    <button class="btn-page" disabled="@(openCurrentPage <= 1)" @onclick="() => GoToOpenPage(openCurrentPage - 1)">‹</button>
                    @for (int pg = openPageStart; pg <= openPageEnd; pg++)
                    {
                        var p = pg;
                        <button class="btn-page @(p == openCurrentPage ? "btn-page-active" : "")" @onclick="() => GoToOpenPage(p)">@p</button>
                    }
                    <button class="btn-page" disabled="@(openCurrentPage >= openTotalPages)" @onclick="() => GoToOpenPage(openCurrentPage + 1)">›</button>
                    <button class="btn-page" disabled="@(openCurrentPage >= openTotalPages)" @onclick="() => GoToOpenPage(openTotalPages)">»</button>
                    <span class="text-muted" style="font-size:0.72rem; margin-left:0.5rem">@openTotalCount items</span>
                </div>
            }
        }
        else
        {
            <p class="text-muted" style="padding:1rem">No open positions</p>
        }
    }
    else
    {
        <!-- Closed Positions -->
        @if (closedPositions.Any())
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="sortable" @onclick='() => closedSort.Toggle("symbol")'>Symbol@(closedSort.Arrow("symbol"))</th>
                            <th class="sortable" @onclick='() => closedSort.Toggle("entry")'>Entry@(closedSort.Arrow("entry"))</th>
                            <th class="sortable" @onclick='() => closedSort.Toggle("exit")'>Exit@(closedSort.Arrow("exit"))</th>
                            <th>Qty</th>
                            <th class="sortable" @onclick='() => closedSort.Toggle("pnl")'>P&L ($)@(closedSort.Arrow("pnl"))</th>
                            <th class="sortable" @onclick='() => closedSort.Toggle("pnlPct")'>P&L (%)@(closedSort.Arrow("pnlPct"))</th>
                            <th class="sortable" @onclick='() => closedSort.Toggle("reason")'>Exit Reason@(closedSort.Arrow("reason"))</th>
                            <th class="sortable" @onclick='() => closedSort.Toggle("holdDays")'>Hold Days@(closedSort.Arrow("holdDays"))</th>
                            <th>Entry Date</th>
                            <th>Exit Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in SortedClosed)
                        {
                            var pnlClass = (p.RealizedPct ?? 0) >= 0 ? "text-green" : "text-red";
                            <tr>
                                <td><SymbolLink Symbol="@p.Symbol" OnSymbolClick="OpenModal" /></td>
                                <td>$@p.EntryPrice.ToString("F2")</td>
                                <td>@(p.ExitPrice != null ? $"${p.ExitPrice:F2}" : "--")</td>
                                <td>@p.Qty</td>
                                <td class="@pnlClass">
                                    @(p.RealizedPnl != null ? $"{(p.RealizedPnl >= 0 ? "+" : "")}${p.RealizedPnl:F2}" : "--")
                                </td>
                                <td class="@pnlClass">
                                    @(p.RealizedPct != null ? $"{(p.RealizedPct >= 0 ? "+" : "")}{p.RealizedPct * 100:F2}%" : "--")
                                </td>
                                <td>
                                    <span class="exit-reason-chip @GetExitReasonClass(p.ExitReason)">
                                        @(p.ExitReason ?? "--")
                                    </span>
                                </td>
                                <td>@(p.HoldDays ?? 0)</td>
                                <td>@p.EntryTime.ToString("MM/dd")</td>
                                <td>@(p.ExitTime?.ToString("MM/dd") ?? "--")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Pagination -->
            @if (closedTotalPages > 1)
            {
                <div class="pagination-bar">
                    <button class="btn-page" disabled="@(closedCurrentPage <= 1)" @onclick="() => GoToClosedPage(1)">«</button>
                    <button class="btn-page" disabled="@(closedCurrentPage <= 1)" @onclick="() => GoToClosedPage(closedCurrentPage - 1)">‹</button>
                    @for (int pg = closedPageStart; pg <= closedPageEnd; pg++)
                    {
                        var p = pg;
                        <button class="btn-page @(p == closedCurrentPage ? "btn-page-active" : "")" @onclick="() => GoToClosedPage(p)">@p</button>
                    }
                    <button class="btn-page" disabled="@(closedCurrentPage >= closedTotalPages)" @onclick="() => GoToClosedPage(closedCurrentPage + 1)">›</button>
                    <button class="btn-page" disabled="@(closedCurrentPage >= closedTotalPages)" @onclick="() => GoToClosedPage(closedTotalPages)">»</button>
                    <span class="text-muted" style="font-size:0.72rem; margin-left:0.5rem">@closedTotalCount items</span>
                </div>
            }
        }
        else
        {
            <p class="text-muted" style="padding:1rem">No closed positions</p>
        }
    }
</div>

<SymbolDetailModal Visible="@modalVisible" Symbol="@modalSymbol" OnClose="CloseModal" />

@code {
    private List<SwingPosition> openPositions = new();
    private List<SwingPosition> closedPositions = new();
    private bool showOpen = true;

    // Pagination
    private const int PageSize = 10;
    private int openCurrentPage = 1;
    private int openTotalCount;
    private int openTotalPages => Math.Max(1, (int)Math.Ceiling((double)openTotalCount / PageSize));
    private int openPageStart => Math.Max(1, openCurrentPage - 2);
    private int openPageEnd => Math.Min(openTotalPages, openPageStart + 4);

    private int closedCurrentPage = 1;
    private int closedTotalCount;
    private int closedTotalPages => Math.Max(1, (int)Math.Ceiling((double)closedTotalCount / PageSize));
    private int closedPageStart => Math.Max(1, closedCurrentPage - 2);
    private int closedPageEnd => Math.Min(closedTotalPages, closedPageStart + 4);

    // Sort state
    private SortState openSort = new();
    private SortState closedSort = new();

    private static readonly Dictionary<string, Func<SwingPosition, object>> OpenSelectors = new()
    {
        ["symbol"] = p => p.Symbol,
        ["qty"] = p => (double)p.Qty,
        ["entry"] = p => (double)p.EntryPrice,
        ["pnl"] = p => (double)(p.UnrealizedPnl ?? 0),
        ["pnlPct"] = p => p.UnrealizedPct ?? 0,
        ["holdDays"] = p => (DateTime.Now - p.EntryTime).Days,
    };

    private static readonly Dictionary<string, Func<SwingPosition, object>> ClosedSelectors = new()
    {
        ["symbol"] = p => p.Symbol,
        ["entry"] = p => (double)p.EntryPrice,
        ["exit"] = p => (double)(p.ExitPrice ?? 0),
        ["pnl"] = p => (double)(p.RealizedPnl ?? 0),
        ["pnlPct"] = p => p.RealizedPct ?? 0,
        ["reason"] = p => p.ExitReason ?? "",
        ["holdDays"] = p => p.HoldDays ?? 0,
    };

    private IEnumerable<SwingPosition> SortedOpen => openSort.Apply(openPositions, OpenSelectors);
    private IEnumerable<SwingPosition> SortedClosed => closedSort.Apply(closedPositions, ClosedSelectors);

    // Modal state
    private bool modalVisible;
    private string modalSymbol = "";
    private void OpenModal(string symbol) { modalSymbol = symbol; modalVisible = true; }
    private void CloseModal() { modalVisible = false; }

    // Crowding + Short Interest
    private bool crowdingLoaded;
    private bool crowdingLoading;
    private System.Text.Json.JsonElement? crowdingData;
    private Dictionary<string, System.Text.Json.JsonElement> shortInterestData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadPositions();
        _ = LoadCrowding();  // fire and forget
    }

    private async Task LoadCrowding()
    {
        crowdingLoading = true;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");

            // Factor Crowding
            var crowdResp = await client.GetAsync("/factor-crowding");
            if (crowdResp.IsSuccessStatusCode)
            {
                crowdingData = await crowdResp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            }

            // Short Interest for each open position
            shortInterestData.Clear();
            foreach (var p in openPositions)
            {
                try
                {
                    var siResp = await client.GetAsync($"/short-interest/{p.Symbol}");
                    if (siResp.IsSuccessStatusCode)
                    {
                        var si = await siResp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                        shortInterestData[p.Symbol] = si;
                    }
                }
                catch { }
            }
        }
        catch { }
        finally
        {
            crowdingLoaded = true;
            crowdingLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPositions()
    {
        try
        {
            var openOffset = (openCurrentPage - 1) * PageSize;
            var closedOffset = (closedCurrentPage - 1) * PageSize;
            var openTask = Db.GetPositionsPagedAsync("open", openOffset, PageSize);
            var closedTask = Db.GetPositionsPagedAsync("closed", closedOffset, PageSize);
            await Task.WhenAll(openTask, closedTask);
            openPositions = openTask.Result.Items;
            openTotalCount = openTask.Result.TotalCount;
            closedPositions = closedTask.Result.Items;
            closedTotalCount = closedTask.Result.TotalCount;
        }
        catch { }
    }

    private async Task SwitchToOpen()
    {
        showOpen = true;
        openCurrentPage = 1;
        await LoadPositions();
    }

    private async Task SwitchToClosed()
    {
        showOpen = false;
        closedCurrentPage = 1;
        await LoadPositions();
    }

    private async Task GoToOpenPage(int pg)
    {
        if (pg < 1 || pg > openTotalPages || pg == openCurrentPage) return;
        openCurrentPage = pg;
        await LoadPositions();
    }

    private async Task GoToClosedPage(int pg)
    {
        if (pg < 1 || pg > closedTotalPages || pg == closedCurrentPage) return;
        closedCurrentPage = pg;
        await LoadPositions();
    }

    private string GetExitReasonClass(string? reason) => reason switch
    {
        "stop_loss" => "exit-sl",
        "take_profit" => "exit-tp",
        "trend_break" => "exit-trend",
        "partial_exit" => "exit-partial",
        "trailing_stop" => "exit-trail",
        _ => ""
    };
}
