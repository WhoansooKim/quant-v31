@page "/login"
@layout QuantDashboard.Components.Layout.LoginLayout
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Swing V4 - Login</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <span class="brand-icon login-brand-icon">S</span>
            <h2>Swing V4</h2>
            <p class="login-subtitle">Semi-Auto Swing Trading System</p>
        </div>

        @if (_errorType == "invalid")
        {
            <div class="login-error">Invalid username or password</div>
        }
        else if (_errorType == "not_approved")
        {
            <div class="login-error" style="background:rgba(234,179,8,0.15); border-color:#eab308; color:#eab308">
                <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">hourglass_top</span>
                Account pending admin approval
            </div>
        }

        @if (_registered)
        {
            <div class="login-error" style="background:rgba(34,197,94,0.15); border-color:#22c55e; color:#22c55e">
                <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">check_circle</span>
                Registration complete! Please wait for admin approval.
            </div>
        }

        <form method="post" action="/account/login">
            <div class="login-field">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" autocomplete="username"
                       required autofocus placeholder="Enter username" />
            </div>
            <div class="login-field">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" autocomplete="current-password"
                       required placeholder="Enter password" />
            </div>
            <button type="submit" class="login-btn">Sign In</button>
        </form>

        <div class="login-register-link">
            <span class="text-muted">Don't have an account?</span>
            <a href="/register">Sign Up</a>
        </div>

        <div class="login-footer">
            <span>Swing Strategy</span>
            <span>Semi-Auto Workflow</span>
            <span>KIS Broker</span>
        </div>
    </div>
</div>

@code {
    private string? _errorType;
    private bool _registered;

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "registered")]
    public string? Registered { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Error) && Error != "0")
            _errorType = Error == "1" ? "invalid" : Error;
        _registered = Registered == "1";
    }
}
