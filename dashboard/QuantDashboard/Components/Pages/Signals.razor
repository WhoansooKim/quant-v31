@page "/signals"
@attribute [Authorize]
@inject SwingService Db
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Swing V4 - Signals</PageTitle>

<div class="page-header">
    <h3>Trade Signals</h3>
    <div style="display:flex; gap:0.5rem">
        <button class="btn-action" style="background:var(--accent-blue, #60a5fa)" @onclick="ScoreAll" disabled="@scoring">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">analytics</span>
            @(scoring ? "Scoring..." : "Factor Score")
        </button>
        <button class="btn-action" style="background:var(--accent-purple, #a78bfa)" @onclick="AnalyzeAll" disabled="@analyzing">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">psychology</span>
            @(analyzing ? "Analyzing..." : "AI Analyze")
        </button>
        <button class="btn-action" @onclick="ScanSignals" disabled="@scanning">
            @(scanning ? "Scanning..." : "Scan Now")
        </button>
    </div>
</div>

<!-- Status Tabs -->
<div class="tab-bar">
    @foreach (var tab in new[] { "pending", "approved", "executed", "rejected", "expired", "all" })
    {
        <button class="tab-btn @(activeTab == tab ? "active" : "")"
                @onclick="() => SetTab(tab)">
            @tab.ToUpper()
            @if (tab == "pending" && pendingCount > 0)
            {
                <span class="tab-badge">@pendingCount</span>
            }
        </button>
    }
</div>

@if (!string.IsNullOrEmpty(statusMsg))
{
    <div class="alert-info" style="margin:0.5rem 0">@statusMsg</div>
}

<!-- Signals Table -->
<div class="section-card" style="margin-top:0.5rem">
    @if (signals.Any())
    {
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="sortable" @onclick='() => ToggleSort("time")'>Time@(sigSort.Arrow("time"))</th>
                        <th class="sortable" @onclick='() => ToggleSort("symbol")'>Symbol@(sigSort.Arrow("symbol"))</th>
                        <th class="sortable" @onclick='() => ToggleSort("type")'>Type@(sigSort.Arrow("type"))</th>
                        <th class="sortable" @onclick='() => ToggleSort("price")'>Price@(sigSort.Arrow("price"))</th>
                        <th>SL</th>
                        <th>TP</th>
                        <th class="sortable" title="20d Return Rank" @onclick='() => ToggleSort("rank")'>Rank@(sigSort.Arrow("rank"))</th>
                        <th title="Trend Aligned">Trend</th>
                        <th title="5d Breakout">Break</th>
                        <th title="Volume Surge">Vol</th>
                        <th class="sortable" title="AI Sentiment Score" @onclick='() => ToggleSort("ai")'>AI@(sigSort.Arrow("ai"))</th>
                        <th class="sortable" title="5-Factor Composite (T+S+F+Q+V, Regime-Adaptive)" @onclick='() => ToggleSort("composite")'>Score@(sigSort.Arrow("composite"))</th>
                        <th class="sortable" @onclick='() => ToggleSort("status")'>Status@(sigSort.Arrow("status"))</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in SortedSignals)
                    {
                        <tr class="@(s.Status == "pending" ? "row-highlight" : "")" @ondblclick="() => OpenModal(s.Symbol)" style="cursor:pointer">
                            <td>@s.Time.ToString("MM/dd HH:mm")</td>
                            <td style="font-weight:700"><a href="https://edition.cnn.com/markets/stocks/@s.Symbol" target="_blank" rel="noopener" @onclick:stopPropagation="true" style="color:var(--primary); text-decoration:none">@s.Symbol</a></td>
                            <td>
                                <span class="badge @(s.SignalType == "ENTRY" ? "badge-green" : "badge-red")">
                                    @s.SignalType
                                </span>
                            </td>
                            <td>@(s.EntryPrice != null ? $"${s.EntryPrice:F2}" : "--")</td>
                            <td class="text-red">@(s.StopLoss != null ? $"${s.StopLoss:F2}" : "--")</td>
                            <td class="text-green">@(s.TakeProfit != null ? $"${s.TakeProfit:F2}" : "--")</td>
                            <td>@(s.Return20dRank != null ? $"{s.Return20dRank:P0}" : "--")</td>
                            <td class="@(s.TrendAligned ? "text-green" : "text-red")">
                                <span class="material-symbols-outlined" style="font-size:16px">@(s.TrendAligned ? "check_circle" : "cancel")</span>
                            </td>
                            <td class="@(s.Breakout5d ? "text-green" : "text-red")">
                                <span class="material-symbols-outlined" style="font-size:16px">@(s.Breakout5d ? "check_circle" : "cancel")</span>
                            </td>
                            <td class="@(s.VolumeSurge ? "text-green" : "text-red")">
                                <span class="material-symbols-outlined" style="font-size:16px">@(s.VolumeSurge ? "check_circle" : "cancel")</span>
                            </td>
                            <td>
                                @if (s.LlmScore != null)
                                {
                                    <span class="ai-score ai-score-@GetAiScoreClass(s.LlmScore.Value)"
                                          title="@GetAiTooltip(s)" style="cursor:pointer"
                                          @onclick="() => ShowAiDetail(s)">
                                        @s.LlmScore
                                    </span>
                                }
                                else
                                {
                                    <button class="btn-sm btn-ai" title="Run AI Analysis"
                                            @onclick="() => AnalyzeSingle(s.SignalId)"
                                            disabled="@analyzing">
                                        <span class="material-symbols-outlined" style="font-size:14px">psychology</span>
                                    </button>
                                }
                            </td>
                            <td>
                                @if (s.CompositeScore != null)
                                {
                                    <span class="composite-score composite-@GetCompositeClass(s.CompositeScore.Value)"
                                          title="T:@(s.TechnicalScore?.ToString("F0") ?? "-") S:@(s.SentimentScore?.ToString("F0") ?? "-") F:@(s.FlowScore?.ToString("F0") ?? "-") Q:@(s.QualityScore?.ToString("F0") ?? "-") V:@(s.ValueScore?.ToString("F0") ?? "-")"
                                          style="cursor:pointer"
                                          @onclick="() => ShowFactorDetail(s)">
                                        @(s.CompositeScore?.ToString("F0"))
                                    </span>
                                }
                                else
                                {
                                    <button class="btn-sm btn-score" title="Run Factor Scoring"
                                            @onclick="() => ScoreSingle(s.SignalId)"
                                            disabled="@scoring">
                                        <span class="material-symbols-outlined" style="font-size:14px">analytics</span>
                                    </button>
                                }
                            </td>
                            <td>
                                <span class="status-chip status-@s.Status">@s.Status</span>
                            </td>
                            <td>
                                @if (s.Status == "pending")
                                {
                                    <button class="btn-sm btn-approve"
                                            @onclick="() => ApproveSignal(s.SignalId)"
                                            disabled="@processing">
                                        Approve
                                    </button>
                                    <button class="btn-sm btn-reject"
                                            @onclick="() => RejectSignal(s.SignalId)"
                                            disabled="@processing">
                                        Reject
                                    </button>
                                }
                                else if (s.Status == "approved" || s.Status == "rejected" || s.Status == "executed")
                                {
                                    <button class="btn-sm btn-revert"
                                            @onclick="() => RevertToPending(s.SignalId)"
                                            disabled="@processing">
                                        Revert
                                    </button>
                                }
                                else if (s.ExitReason != null)
                                {
                                    <span class="text-muted">@s.ExitReason</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        @if (sigTotalPages > 1)
        {
            <div class="pagination-bar">
                <button class="btn-page" disabled="@(sigCurrentPage <= 1)" @onclick="() => GoToSigPage(1)">«</button>
                <button class="btn-page" disabled="@(sigCurrentPage <= 1)" @onclick="() => GoToSigPage(sigCurrentPage - 1)">‹</button>
                @for (int pg = sigPageStart; pg <= sigPageEnd; pg++)
                {
                    var p = pg;
                    <button class="btn-page @(p == sigCurrentPage ? "btn-page-active" : "")" @onclick="() => GoToSigPage(p)">@p</button>
                }
                <button class="btn-page" disabled="@(sigCurrentPage >= sigTotalPages)" @onclick="() => GoToSigPage(sigCurrentPage + 1)">›</button>
                <button class="btn-page" disabled="@(sigCurrentPage >= sigTotalPages)" @onclick="() => GoToSigPage(sigTotalPages)">»</button>
                <span class="text-muted" style="font-size:0.72rem; margin-left:0.5rem">@sigTotalCount items</span>
            </div>
        }
    }
    else
    {
        <p class="text-muted" style="padding:1rem">No signals found for this filter</p>
    }
</div>

<!-- AI Analysis Detail Popup -->
@if (aiDetailVisible && aiDetailSignal != null)
{
    <div class="modal-overlay" @onclick="CloseAiDetail">
        <div class="modal-panel" style="max-width:500px" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>AI Analysis — @aiDetailSignal.Symbol</h4>
                <button class="btn-close" @onclick="CloseAiDetail">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="modal-body">
                <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1rem">
                    <span class="ai-score-large ai-score-@GetAiScoreClass(aiDetailSignal.LlmScore ?? 0)">
                        @(aiDetailSignal.LlmScore ?? 0)
                    </span>
                    <div>
                        <div class="text-muted" style="font-size:0.75rem">AI Confidence Score</div>
                        <div style="font-size:0.85rem">@GetAiScoreLabel(aiDetailSignal.LlmScore ?? 0)</div>
                    </div>
                </div>
                @if (aiParsed != null)
                {
                    <div class="ai-section">
                        <div class="ai-section-label">Reasoning</div>
                        <div class="ai-section-text">@(aiParsed.GetValueOrDefault("reasoning", "N/A"))</div>
                    </div>
                    <div class="ai-section">
                        <div class="ai-section-label">Risk Factors</div>
                        <div class="ai-section-text text-red">@(aiParsed.GetValueOrDefault("risk_factors", "N/A"))</div>
                    </div>
                    <div class="ai-section">
                        <div class="ai-section-label">News Summary</div>
                        <div class="ai-section-text">@(aiParsed.GetValueOrDefault("news_summary", "N/A"))</div>
                    </div>
                    <div class="text-muted" style="font-size:0.7rem; margin-top:0.5rem">
                        Model: @(aiParsed.GetValueOrDefault("model", "unknown"))
                        @if (aiDetailSignal.LlmAnalyzedAt != null)
                        {
                            <span> | Analyzed: @aiDetailSignal.LlmAnalyzedAt.Value.ToString("MM/dd HH:mm")</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Factor Score Detail Popup -->
@if (factorDetailVisible && factorDetailSignal != null)
{
    <div class="modal-overlay" @onclick="CloseFactorDetail">
        <div class="modal-panel" style="max-width:520px" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Factor Score — @factorDetailSignal.Symbol</h4>
                <button class="btn-close" @onclick="CloseFactorDetail">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="modal-body">
                <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1rem">
                    <span class="composite-score-large composite-@GetCompositeClass(factorDetailSignal.CompositeScore ?? 0)">
                        @(factorDetailSignal.CompositeScore?.ToString("F0") ?? "—")
                    </span>
                    <div>
                        <div class="text-muted" style="font-size:0.75rem">Composite Score</div>
                        <div style="font-size:0.85rem">@GetCompositeLabel(factorDetailSignal.CompositeScore ?? 0)</div>
                    </div>
                </div>
                <!-- Regime Badge -->
                @if (factorParsed != null && factorParsed.TryGetValue("regime", out var regimeObj))
                {
                    var regime = regimeObj?.ToString() ?? "MIXED";
                    <div style="margin-bottom:0.5rem">
                        <span class="badge" style="background:@(regime == "TRENDING" ? "#22c55e" : regime == "SIDEWAYS" ? "#eab308" : regime == "HIGH_VOL" ? "#ef4444" : "#60a5fa"); font-size:0.7rem; padding:2px 8px">
                            @regime
                        </span>
                        <span class="text-muted" style="font-size:0.7rem; margin-left:0.3rem">Regime-Adaptive Weights</span>
                    </div>
                }
                <!-- Factor Bars -->
                <div class="factor-bars">
                    <div class="factor-row">
                        <span class="factor-label">Technical</span>
                        <div class="factor-bar-bg">
                            <div class="factor-bar factor-bar-tech" style="width:@(factorDetailSignal.TechnicalScore ?? 0)%"></div>
                        </div>
                        <span class="factor-val">@(factorDetailSignal.TechnicalScore?.ToString("F0") ?? "-")</span>
                    </div>
                    <div class="factor-row">
                        <span class="factor-label">Sentiment</span>
                        <div class="factor-bar-bg">
                            <div class="factor-bar factor-bar-sent" style="width:@(factorDetailSignal.SentimentScore ?? 0)%"></div>
                        </div>
                        <span class="factor-val">@(factorDetailSignal.SentimentScore?.ToString("F0") ?? "-")</span>
                    </div>
                    <div class="factor-row">
                        <span class="factor-label">Flow</span>
                        <div class="factor-bar-bg">
                            <div class="factor-bar factor-bar-flow" style="width:@(factorDetailSignal.FlowScore ?? 0)%"></div>
                        </div>
                        <span class="factor-val">@(factorDetailSignal.FlowScore?.ToString("F0") ?? "-")</span>
                    </div>
                    <div class="factor-row">
                        <span class="factor-label">Quality</span>
                        <div class="factor-bar-bg">
                            <div class="factor-bar" style="width:@(factorDetailSignal.QualityScore ?? 0)%; background:#a78bfa"></div>
                        </div>
                        <span class="factor-val">@(factorDetailSignal.QualityScore?.ToString("F0") ?? "-")</span>
                    </div>
                    <div class="factor-row">
                        <span class="factor-label">Value</span>
                        <div class="factor-bar-bg">
                            <div class="factor-bar" style="width:@(factorDetailSignal.ValueScore ?? 0)%; background:#f59e0b"></div>
                        </div>
                        <span class="factor-val">@(factorDetailSignal.ValueScore?.ToString("F0") ?? "-")</span>
                    </div>
                    <div class="factor-row">
                        <span class="factor-label">Macro</span>
                        <div class="factor-bar-bg">
                            <div class="factor-bar" style="width:@(factorDetailSignal.MacroScore ?? 0)%; background:#06b6d4"></div>
                        </div>
                        <span class="factor-val">@(factorDetailSignal.MacroScore?.ToString("F0") ?? "-")</span>
                    </div>
                </div>
                @if (factorParsed != null)
                {
                    <!-- LSTM Detail (inside Technical) -->
                    @if (factorParsed.TryGetValue("technical", out var techObj) && techObj is System.Text.Json.JsonElement techEl && techEl.TryGetProperty("lstm", out var lstmEl) && lstmEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                    {
                        <div class="ai-section" style="margin-top:0.75rem">
                            <div class="ai-section-label">LSTM Prediction</div>
                            <div class="ai-section-text">
                                @{
                                    var upProb = lstmEl.TryGetProperty("up_probability", out var up) ? up.GetDouble() : 0.5;
                                    var conf = lstmEl.TryGetProperty("confidence", out var cf) ? cf.GetDouble() : 0;
                                    var lstmSc = lstmEl.TryGetProperty("lstm_score", out var ls) ? ls.GetDouble() : 50;
                                    var lstmW = lstmEl.TryGetProperty("weight", out var lw) ? lw.GetDouble() : 0;
                                }
                                <span style="color:@(upProb > 0.6 ? "#22c55e" : upProb < 0.4 ? "#ef4444" : "#eab308")">
                                    상승 확률 @(upProb.ToString("P0"))
                                </span>
                                <span class="text-muted"> (신뢰도 @(conf.ToString("P0")), LSTM 점수 @(lstmSc.ToString("F0")), 비중 @(lstmW.ToString("P0")))</span>
                            </div>
                        </div>
                    }
                    <!-- Sentiment Detail (News + Social) -->
                    @if (factorParsed.TryGetValue("sentiment", out var sentObj) && sentObj is System.Text.Json.JsonElement sentEl)
                    {
                        <div class="ai-section" style="margin-top:0.75rem">
                            <div class="ai-section-label">Sentiment Detail</div>
                            <div class="ai-section-text">
                                @(sentEl.TryGetProperty("source", out var src) ? src.GetString() : "")
                                @if (sentEl.TryGetProperty("news", out var newsEl) && newsEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                                {
                                    <span> | 뉴스: @(newsEl.TryGetProperty("news_count", out var nc) ? nc.GetInt32().ToString() : "0")건</span>
                                    @if (newsEl.TryGetProperty("summary", out var nsum) && nsum.ValueKind == System.Text.Json.JsonValueKind.String)
                                    {
                                        <span> — @nsum.GetString()</span>
                                    }
                                }
                                @if (sentEl.TryGetProperty("social", out var socEl) && socEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                                {
                                    <br/>
                                    <span style="color:#8b5cf6">소셜: 멘션 @(socEl.TryGetProperty("mention_count", out var mc) ? mc.GetInt32().ToString() : "0")건</span>
                                    @if (socEl.TryGetProperty("combined_raw", out var craw))
                                    {
                                        var rawScore = craw.GetDouble();
                                        <span style="color:@(rawScore > 20 ? "#22c55e" : rawScore < -20 ? "#ef4444" : "#eab308")">
                                            (점수 @(rawScore.ToString("F0")))
                                        </span>
                                    }
                                }
                            </div>
                        </div>
                    }
                    @if (factorParsed.TryGetValue("flow", out var flowObj) && flowObj is System.Text.Json.JsonElement flowEl)
                    {
                        <div class="ai-section">
                            <div class="ai-section-label">Flow Detail</div>
                            <div class="ai-section-text">
                                @if (flowEl.TryGetProperty("insider", out var ins))
                                {
                                    <span>Insider: Buy @(ins.TryGetProperty("buys", out var b) ? b.ToString() : "0") / Sell @(ins.TryGetProperty("sells", out var sl) ? sl.ToString() : "0")</span>
                                }
                                @if (flowEl.TryGetProperty("recommendations", out var rec))
                                {
                                    <span> | Analyst: Buy @(rec.TryGetProperty("buy", out var rb) ? rb.ToString() : "0") Hold @(rec.TryGetProperty("hold", out var rh) ? rh.ToString() : "0") Sell @(rec.TryGetProperty("sell", out var rs) ? rs.ToString() : "0")</span>
                                }
                            </div>
                        </div>
                    }
                    @if (factorParsed.TryGetValue("quality", out var qualObj) && qualObj is System.Text.Json.JsonElement qualEl)
                    {
                        <div class="ai-section">
                            <div class="ai-section-label">Quality Detail</div>
                            <div class="ai-section-text">
                                ROE: @(qualEl.TryGetProperty("roe_pts", out var rp) ? rp.ToString() : "-")pt
                                | Margin: @(qualEl.TryGetProperty("gross_margin_pts", out var gp) ? gp.ToString() : "-")pt
                                | D/E: @(qualEl.TryGetProperty("debt_equity_pts", out var dp) ? dp.ToString() : "-")pt
                                | Stability: @(qualEl.TryGetProperty("stability_pts", out var sp) ? sp.ToString() : "-")pt
                            </div>
                        </div>
                    }
                    @if (factorParsed.TryGetValue("value", out var valObj) && valObj is System.Text.Json.JsonElement valEl)
                    {
                        <div class="ai-section">
                            <div class="ai-section-label">Value Detail</div>
                            <div class="ai-section-text">
                                P/E: @(valEl.TryGetProperty("pe_pts", out var pp) ? pp.ToString() : "-")pt
                                | P/B: @(valEl.TryGetProperty("pb_pts", out var pbp) ? pbp.ToString() : "-")pt
                                | FCF: @(valEl.TryGetProperty("fcf_yield_pts", out var fp) ? fp.ToString() : "-")pt
                                | EV/EBITDA: @(valEl.TryGetProperty("ev_ebitda_pts", out var ep) ? ep.ToString() : "-")pt
                            </div>
                        </div>
                    }
                }
                <!-- Macro Overlay -->
                @if (macroData.HasValue)
                {
                    var md = macroData.Value;
                    var regime = md.TryGetProperty("regime", out var rg) ? rg.GetString() : "NEUTRAL";
                    var regimeColor = regime switch { "RISK_ON" => "#22c55e", "NEUTRAL" => "#eab308", "RISK_OFF" => "#f97316", "CRISIS" => "#ef4444", _ => "#94a3b8" };
                    <div class="ai-section" style="margin-top:0.75rem">
                        <div class="ai-section-label">
                            Macro Overlay
                            <span style="margin-left:0.5rem; padding:1px 6px; border-radius:4px; font-size:0.7rem; color:white; background:@regimeColor">@regime</span>
                        </div>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.3rem; font-size:0.78rem; margin-top:0.3rem">
                            @{
                                var subs = new[] {
                                    ("risk_off", "Risk-Off"), ("yield_curve", "Yield Curve"),
                                    ("copper_gold", "Cu/Au"), ("dollar_trend", "Dollar"),
                                    ("btc_momentum", "BTC Mom")
                                };
                            }
                            @foreach (var (key, label) in subs)
                            {
                                if (md.TryGetProperty(key, out var sub) && sub.TryGetProperty("score", out var sc))
                                {
                                    var sv = sc.GetDouble();
                                    <span>@label: <b style="color:@(sv >= 60 ? "#22c55e" : sv >= 40 ? "#eab308" : "#ef4444")">@sv.ToString("F0")</b></span>
                                }
                            }
                        </div>
                        @if (md.TryGetProperty("raw_data", out var raw))
                        {
                            <div class="text-muted" style="font-size:0.7rem; margin-top:0.25rem">
                                VIX=@(raw.TryGetProperty("vix", out var v) && v.ValueKind != System.Text.Json.JsonValueKind.Null ? v.GetDouble().ToString("F1") : "-")
                                | 10Y=@(raw.TryGetProperty("yield_10y", out var y) && y.ValueKind != System.Text.Json.JsonValueKind.Null ? y.GetDouble().ToString("F2") + "%" : "-")
                                | DXY=@(raw.TryGetProperty("dxy", out var d) && d.ValueKind != System.Text.Json.JsonValueKind.Null ? d.GetDouble().ToString("F1") : "-")
                            </div>
                        }
                        @if (macroRiskAdj.HasValue)
                        {
                            var ra = macroRiskAdj.Value;
                            var ps = ra.GetProperty("position_sizing");
                            var ts = ra.GetProperty("trailing_stop");
                            var mult = ps.GetProperty("multiplier").GetDouble();
                            var adjPct = ps.GetProperty("adjusted_position_pct").GetDouble();
                            var blocked = ps.GetProperty("entry_blocked").GetBoolean();
                            <div style="font-size:0.72rem; margin-top:0.4rem; padding:0.3rem 0.5rem; background:rgba(6,182,212,0.08); border-radius:4px">
                                <span style="font-weight:600; color:#06b6d4">Risk Adjustment:</span>
                                Position <b>@(adjPct.ToString("P0"))</b>
                                <span class="text-muted">(×@mult.ToString("F0")%)</span>
                                | Trail <b>@(ts.GetProperty("adjusted_activation").GetDouble().ToString("P1"))</b>/@(ts.GetProperty("adjusted_distance").GetDouble().ToString("P1"))
                                | Partial <b>@(ts.GetProperty("adjusted_partial_threshold").GetDouble().ToString("P1"))</b>
                                @if (blocked)
                                {
                                    <span style="color:#ef4444; font-weight:700"> | ENTRY BLOCKED</span>
                                }
                            </div>
                        }
                    </div>
                }
                <!-- Crowding + Short Interest -->
                @if (symbolCrowding.HasValue)
                {
                    var sc = symbolCrowding.Value;
                    <div class="ai-section" style="margin-top:0.5rem">
                        <div class="ai-section-label">Factor Crowding</div>
                        <div class="ai-section-text">
                            @if (sc.TryGetProperty("factor_memberships", out var fm))
                            {
                                var members = fm.EnumerateArray().Select(x => x.GetString()).ToList();
                                if (members.Any())
                                {
                                    @foreach (var m in members)
                                    {
                                        <span class="badge badge-yellow" style="font-size:0.68rem; padding:1px 5px; margin-right:3px">@m</span>
                                    }
                                    var risk = sc.TryGetProperty("risk_level", out var rl) ? rl.GetString() : "low";
                                    <span class="text-muted" style="font-size:0.7rem"> — @risk risk</span>
                                }
                                else
                                {
                                    <span class="text-muted">No factor ETF overlap</span>
                                }
                            }
                        </div>
                    </div>
                }
                @if (symbolShortInterest.HasValue)
                {
                    var si = symbolShortInterest.Value;
                    var ratio = si.TryGetProperty("short_ratio", out var sr) ? sr.GetDouble() : 0;
                    var change = si.TryGetProperty("change_pct", out var cp) ? cp.GetDouble() : 0;
                    var available = si.TryGetProperty("available", out var av) && av.GetBoolean();
                    if (available)
                    {
                        <div class="ai-section">
                            <div class="ai-section-label">Short Interest</div>
                            <div class="ai-section-text">
                                SIR: <b style="color:@(ratio > 10 ? "#ef4444" : ratio > 5 ? "#eab308" : "#22c55e")">@ratio.ToString("F1") days</b>
                                @if (change != 0)
                                {
                                    <span> | Change: <span style="color:@(change < 0 ? "#22c55e" : "#ef4444")">@(change > 0 ? "+" : "")@change.ToString("F1")%</span></span>
                                }
                                @if (si.TryGetProperty("short_pct_float", out var spf) && spf.GetDouble() > 0)
                                {
                                    <span> | Float: @spf.GetDouble().ToString("F1")%</span>
                                }
                            </div>
                        </div>
                    }
                }

                <!-- Fundamental Analysis -->
                <div style="margin-top:0.75rem; padding-top:0.5rem; border-top:1px solid var(--border)">
                    @if (fundamentalResult.HasValue)
                    {
                        var fr = fundamentalResult.Value;
                        <div class="ai-section">
                            <div class="ai-section-label">
                                Fundamental Score
                                <span class="composite-score composite-@GetCompositeClass(fundamentalScore)" style="margin-left:0.5rem">@fundamentalScore</span>
                            </div>
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.3rem; font-size:0.78rem; margin-top:0.3rem">
                                <span>Revenue Growth: <b>@(fr.TryGetProperty("revenue_growth", out var rg) ? rg.ToString() : "-")</b></span>
                                <span>Margin Trend: <b>@(fr.TryGetProperty("margin_trend", out var mt) ? mt.ToString() : "-")</b></span>
                                <span>Debt Health: <b>@(fr.TryGetProperty("debt_health", out var dh) ? dh.ToString() : "-")</b></span>
                                <span>Guidance: <b>@(fr.TryGetProperty("guidance", out var gu) ? gu.ToString() : "-")</b></span>
                            </div>
                            @if (fr.TryGetProperty("summary", out var fsum))
                            {
                                <div class="ai-section-text" style="margin-top:0.3rem; font-size:0.75rem">@fsum.GetString()</div>
                            }
                        </div>
                    }
                    else
                    {
                        <button class="btn-sm btn-ai" style="width:100%" @onclick="() => RunFundamental(factorDetailSignal!.Symbol)" disabled="@analyzingFundamental">
                            <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle">lab_research</span>
                            @(analyzingFundamental ? "Analyzing..." : "Run Fundamental Analysis")
                        </button>
                    }
                </div>

                <div class="text-muted" style="font-size:0.7rem; margin-top:0.5rem">
                    @if (factorDetailSignal.FactorScoredAt != null)
                    {
                        <span>Scored: @factorDetailSignal.FactorScoredAt.Value.ToString("MM/dd HH:mm")</span>
                    }
                </div>
            </div>
        </div>
    </div>
}

<SymbolDetailModal Visible="@modalVisible" Symbol="@modalSymbol" OnClose="CloseModal" />

@code {
    private List<SwingSignal> signals = new();
    private string activeTab = "pending";
    private int pendingCount;
    private bool scanning;
    private bool processing;
    private bool analyzing;
    private bool scoring;
    private string? statusMsg;

    // Pagination
    private const int SigPageSize = 10;
    private int sigCurrentPage = 1;
    private int sigTotalCount;
    private int sigTotalPages => Math.Max(1, (int)Math.Ceiling((double)sigTotalCount / SigPageSize));
    private int sigPageStart => Math.Max(1, sigCurrentPage - 2);
    private int sigPageEnd => Math.Min(sigTotalPages, sigPageStart + 4);

    // AI Detail popup
    private bool aiDetailVisible;
    private SwingSignal? aiDetailSignal;
    private Dictionary<string, string>? aiParsed;

    // Factor Detail popup
    private bool factorDetailVisible;
    private SwingSignal? factorDetailSignal;
    private Dictionary<string, object>? factorParsed;

    // Fundamental analysis
    private bool analyzingFundamental;
    private System.Text.Json.JsonElement? fundamentalResult;
    private int fundamentalScore;

    // Crowding + Short Interest (per-symbol, in factor popup)
    private System.Text.Json.JsonElement? symbolCrowding;
    private System.Text.Json.JsonElement? symbolShortInterest;
    private System.Text.Json.JsonElement? macroData;
    private System.Text.Json.JsonElement? macroRiskAdj;

    // Sort state
    private SortState sigSort = new();

    private static readonly Dictionary<string, Func<SwingSignal, object>> SigSelectors = new()
    {
        ["time"] = s => s.Time,
        ["symbol"] = s => s.Symbol,
        ["type"] = s => s.SignalType,
        ["price"] = s => (double)(s.EntryPrice ?? 0),
        ["rank"] = s => s.Return20dRank ?? 0,
        ["ai"] = s => s.LlmScore ?? 0,
        ["composite"] = s => s.CompositeScore ?? 0,
        ["status"] = s => s.Status,
    };

    private IEnumerable<SwingSignal> SortedSignals => sigSort.Apply(signals, SigSelectors);

    // Modal state
    private bool modalVisible;
    private string modalSymbol = "";

    private void OpenModal(string symbol) { modalSymbol = symbol; modalVisible = true; }
    private void CloseModal() { modalVisible = false; }

    protected override async Task OnInitializedAsync()
    {
        await LoadSignals();
    }

    private async Task LoadSignals()
    {
        try
        {
            var status = activeTab == "all" ? null : activeTab;
            var offset = (sigCurrentPage - 1) * SigPageSize;
            var result = await Db.GetSignalsPagedAsync(status, offset, SigPageSize);
            signals = result.Items;
            sigTotalCount = result.TotalCount;
            pendingCount = await Db.GetPendingSignalCountAsync();
        }
        catch (Exception ex) { statusMsg = $"Load error: {ex.Message}"; }
    }

    private async Task SetTab(string tab)
    {
        activeTab = tab;
        sigCurrentPage = 1;
        statusMsg = null;
        await LoadSignals();
    }

    private async Task GoToSigPage(int pg)
    {
        if (pg < 1 || pg > sigTotalPages || pg == sigCurrentPage) return;
        sigCurrentPage = pg;
        await LoadSignals();
    }

    private void ToggleSort(string col)
    {
        sigSort.Toggle(col);
    }

    private async Task ScanSignals()
    {
        scanning = true;
        statusMsg = null;
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/scan", null);
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadAsStringAsync();
                statusMsg = $"Scan completed. {json}";
                activeTab = "pending";
                await LoadSignals();
            }
            else
            {
                statusMsg = $"Scan failed: {resp.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Scan error: {ex.Message}";
        }
        finally
        {
            scanning = false;
        }
    }

    private async Task ApproveSignal(long signalId)
    {
        processing = true;
        statusMsg = null;
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync($"/signals/{signalId}/approve", null);
            if (resp.IsSuccessStatusCode)
            {
                statusMsg = $"Signal #{signalId} approved and executed!";
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                statusMsg = $"Approve failed: {body}";
            }
            await LoadSignals();
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            processing = false;
        }
    }

    private async Task RevertToPending(long signalId)
    {
        processing = true;
        statusMsg = null;
        try
        {
            var ok = await Db.RevertToPendingAsync(signalId);
            statusMsg = ok
                ? $"Signal #{signalId} reverted to pending"
                : $"Signal #{signalId} could not be reverted";
            await LoadSignals();
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            processing = false;
        }
    }

    private async Task RejectSignal(long signalId)
    {
        processing = true;
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync($"/signals/{signalId}/reject", null);
            statusMsg = resp.IsSuccessStatusCode
                ? $"Signal #{signalId} rejected"
                : $"Reject failed: {resp.StatusCode}";
            await LoadSignals();
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            processing = false;
        }
    }

    // ─── AI Analysis Methods ───────────────────────

    private async Task AnalyzeSingle(long signalId)
    {
        analyzing = true;
        statusMsg = null;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync($"/signals/{signalId}/analyze", null);
            if (resp.IsSuccessStatusCode)
            {
                statusMsg = "AI analysis started (1 signal)...";
                StateHasChanged();
                await PollAnalyzeStatus();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                statusMsg = $"AI analysis failed: {body}";
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            analyzing = false;
        }
    }

    private async Task AnalyzeAll()
    {
        analyzing = true;
        statusMsg = null;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/signals/analyze-pending", null);
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                var total = json.TryGetProperty("total", out var t) ? t.GetInt32() : 0;
                var mode = json.TryGetProperty("mode", out var md) ? md.GetString() : "unknown";
                if (total == 0)
                {
                    statusMsg = "No pending signals to analyze.";
                    analyzing = false;
                    return;
                }
                statusMsg = $"AI analysis started: {total} signals ({mode})...";
                StateHasChanged();
                await PollAnalyzeStatus();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                statusMsg = $"AI analysis failed: {body}";
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            analyzing = false;
        }
    }

    private async Task PollAnalyzeStatus()
    {
        var client = HttpFactory.CreateClient("Engine");
        for (int i = 0; i < 120; i++)  // 최대 10분 (120 x 5s)
        {
            await Task.Delay(5000);
            try
            {
                var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/ai/analyze-status");
                var status = resp.TryGetProperty("status", out var s) ? s.GetString() : "idle";
                if (status == "running")
                {
                    var done = resp.TryGetProperty("done", out var d) ? d.GetInt32() : 0;
                    var total = resp.TryGetProperty("total", out var t) ? t.GetInt32() : 0;
                    var current = resp.TryGetProperty("current", out var c) ? c.GetString() : "";
                    statusMsg = $"AI analyzing... {done}/{total} done{(string.IsNullOrEmpty(current) ? "" : $" (now: {current})")}";
                    StateHasChanged();
                    continue;
                }
                if (status == "done")
                {
                    var analyzed = resp.TryGetProperty("analyzed", out var a) ? a.GetInt32() : 0;
                    var mode = resp.TryGetProperty("mode", out var md) ? md.GetString() : "";
                    statusMsg = $"AI analysis completed: {analyzed} signals ({mode})";
                    await LoadSignals();
                    return;
                }
                if (status == "error")
                {
                    var msg = resp.TryGetProperty("message", out var m) ? m.GetString() : "Unknown error";
                    statusMsg = $"AI analysis error: {msg}";
                    return;
                }
                // idle or unknown
                statusMsg = "AI analysis finished.";
                await LoadSignals();
                return;
            }
            catch { /* polling error, retry */ }
        }
        statusMsg = "AI analysis timed out. Check results manually.";
        await LoadSignals();
    }

    private void ShowAiDetail(SwingSignal signal)
    {
        aiDetailSignal = signal;
        aiParsed = null;
        if (!string.IsNullOrEmpty(signal.LlmAnalysis))
        {
            try
            {
                aiParsed = System.Text.Json.JsonSerializer
                    .Deserialize<Dictionary<string, string>>(signal.LlmAnalysis);
            }
            catch { }
        }
        aiDetailVisible = true;
    }

    private void CloseAiDetail() { aiDetailVisible = false; }

    // ─── Factor Scoring Methods ────────────────────

    private async Task ScoreSingle(long signalId)
    {
        scoring = true;
        statusMsg = null;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync($"/signals/{signalId}/score", null);
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                var composite = json.TryGetProperty("composite_score", out var cs) ? cs.GetDouble() : 0;
                statusMsg = $"Factor Score for #{signalId}: {composite:F0}/100";
                await LoadSignals();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                statusMsg = $"Scoring failed: {body}";
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            scoring = false;
        }
    }

    private async Task ScoreAll()
    {
        scoring = true;
        statusMsg = null;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/signals/score-pending", null);
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                var count = json.TryGetProperty("scored", out var cnt) ? cnt.GetInt32() : 0;
                statusMsg = $"Factor scoring completed: {count} signals scored";
                await LoadSignals();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                statusMsg = $"Scoring failed: {body}";
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            scoring = false;
        }
    }

    private async Task ShowFactorDetail(SwingSignal signal)
    {
        factorDetailSignal = signal;
        factorParsed = null;
        fundamentalResult = null;
        fundamentalScore = 0;
        symbolCrowding = null;
        symbolShortInterest = null;
        macroData = null;
        macroRiskAdj = null;
        if (!string.IsNullOrEmpty(signal.FactorDetail))
        {
            try
            {
                factorParsed = System.Text.Json.JsonSerializer
                    .Deserialize<Dictionary<string, object>>(signal.FactorDetail);
            }
            catch { }
        }
        factorDetailVisible = true;
        StateHasChanged();

        // Load crowding + short interest in background
        _ = LoadSymbolExtras(signal.Symbol);
    }

    private async Task LoadSymbolExtras(string symbol)
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var crowdTask = client.GetAsync($"/factor-crowding/{symbol}");
            var siTask = client.GetAsync($"/short-interest/{symbol}");
            var macroTask = client.GetAsync("/macro");
            var riskAdjTask = client.GetAsync("/macro/risk-adjustment");
            await Task.WhenAll(crowdTask, siTask, macroTask, riskAdjTask);

            if (crowdTask.Result.IsSuccessStatusCode)
                symbolCrowding = await crowdTask.Result.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            if (siTask.Result.IsSuccessStatusCode)
                symbolShortInterest = await siTask.Result.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            if (macroTask.Result.IsSuccessStatusCode)
                macroData = await macroTask.Result.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            if (riskAdjTask.Result.IsSuccessStatusCode)
                macroRiskAdj = await riskAdjTask.Result.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();

            StateHasChanged();
        }
        catch { }
    }

    private void CloseFactorDetail()
    {
        factorDetailVisible = false;
        fundamentalResult = null;
        fundamentalScore = 0;
        symbolCrowding = null;
        symbolShortInterest = null;
        macroData = null;
        macroRiskAdj = null;
    }

    private async Task RunFundamental(string symbol)
    {
        analyzingFundamental = true;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.GetAsync($"/fundamental/{symbol}");
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                fundamentalResult = json;
                fundamentalScore = json.TryGetProperty("fundamental_score", out var fs) ? fs.GetInt32() : 0;
            }
        }
        catch { }
        finally
        {
            analyzingFundamental = false;
        }
    }

    private static string GetCompositeClass(double score)
        => score >= 70 ? "high" : score >= 50 ? "mid" : "low";

    private static string GetCompositeLabel(double score)
        => score >= 70 ? "Strong Signal" : score >= 50 ? "Moderate" : "Weak";

    private static string GetAiScoreClass(int score)
        => score >= 8 ? "high" : score >= 5 ? "mid" : "low";

    private static string GetAiScoreLabel(int score)
        => score >= 8 ? "Strong Buy Signal" : score >= 6 ? "Moderate Buy" : score >= 4 ? "Neutral" : "Weak / Caution";

    private static string GetAiTooltip(SwingSignal s)
    {
        if (s.LlmScore == null) return "Not analyzed";
        var label = GetAiScoreLabel(s.LlmScore.Value);
        var time = s.LlmAnalyzedAt?.ToString("MM/dd HH:mm") ?? "";
        return $"AI Score: {s.LlmScore}/10 — {label} ({time})";
    }
}
