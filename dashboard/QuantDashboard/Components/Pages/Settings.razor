@page "/settings"
@attribute [Authorize]
@inject SwingService Db
@inject IHttpClientFactory HttpFactory
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Swing V4 - Settings</PageTitle>

<div class="page-header">
    <h3>Settings</h3>
</div>

@if (!string.IsNullOrEmpty(statusMsg))
{
    <div class="alert-info" style="margin-bottom:0.5rem">@statusMsg</div>
}

@foreach (var category in configs.GroupBy(c => c.Category).OrderBy(g => g.Key))
{
    <div class="section-card" style="margin-bottom:1rem">
        <h4 class="section-title">@category.Key.ToUpper()</h4>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Key</th>
                        <th>Value</th>
                        <th>Description</th>
                        <th>Updated</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cfg in category)
                    {
                        <tr>
                            <td><code>@cfg.Key</code></td>
                            <td>
                                <input type="text"
                                       class="form-input form-input-sm"
                                       value="@(editValues.GetValueOrDefault(cfg.Key, cfg.Value))"
                                       @oninput="e => editValues[cfg.Key] = e.Value?.ToString() ?? cfg.Value"
                                       style="width:120px" />
                            </td>
                            <td class="text-muted">@cfg.Description</td>
                            <td class="text-muted">@cfg.UpdatedAt.ToString("MM/dd HH:mm")</td>
                            <td>
                                @if (editValues.ContainsKey(cfg.Key) && editValues[cfg.Key] != cfg.Value)
                                {
                                    <button class="btn-sm btn-approve"
                                            @onclick="() => SaveConfig(cfg.Key)">
                                        Save
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Trading Mode Toggle -->
<div class="section-card" style="margin-bottom:1rem">
    <h4 class="section-title">TRADING MODE</h4>
    <div class="trading-mode-box">
        <div class="trading-mode-current">
            <span class="trading-mode-icon @(tradingMode == "live" ? "mode-live" : "mode-paper")">
                <span class="material-symbols-outlined">@(tradingMode == "live" ? "currency_exchange" : "science")</span>
            </span>
            <div>
                <div class="trading-mode-label">Current Mode</div>
                <div class="trading-mode-value @(tradingMode == "live" ? "text-red" : "text-green")">
                    @(tradingMode == "live" ? "LIVE TRADING" : "PAPER TRADING")
                </div>
                <div class="text-muted" style="font-size:0.75rem">
                    @(tradingMode == "live"
                        ? "Real money is being used for trades via KIS"
                        : "Simulated trades — no real money involved")
                </div>
            </div>
        </div>

        @if (!showModeConfirm)
        {
            <button class="btn-action @(tradingMode == "live" ? "btn-mode-paper" : "btn-mode-live")"
                    @onclick="StartModeChange"
                    disabled="@modeChanging">
                <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">swap_horiz</span>
                Switch to @(tradingMode == "live" ? "Paper" : "Live")
            </button>
        }
        else
        {
            <div class="mode-confirm-box">
                @if (targetMode == "live")
                {
                    <div class="mode-warning">
                        <span class="material-symbols-outlined">warning</span>
                        <strong>WARNING: Switching to LIVE mode will use REAL MONEY.</strong>
                        All future trade approvals will execute real orders via KIS.
                    </div>
                }
                else
                {
                    <div class="mode-info">
                        <span class="material-symbols-outlined">info</span>
                        Switching to Paper mode. Trades will be simulated.
                    </div>
                }
                <div style="display:flex; gap:0.5rem; margin-top:0.5rem">
                    <button class="btn-sm btn-approve" @onclick="ConfirmModeChange" disabled="@modeChanging">
                        @(modeChanging ? "Changing..." : "Confirm")
                    </button>
                    <button class="btn-sm btn-reject" @onclick="CancelModeChange">Cancel</button>
                </div>
            </div>
        }
    </div>
</div>

<!-- Engine Status -->
<div class="section-card">
    <h4 class="section-title">Engine Status</h4>
    <div class="stat-grid cols-3">
        <div class="stat-card">
            <span class="stat-label">Engine</span>
            <span class="stat-value @(engineOk ? "text-green" : "text-red")">
                @(engineOk ? "Online" : "Offline")
            </span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Database</span>
            <span class="stat-value @(dbOk ? "text-green" : "text-red")">
                @(dbOk ? "Connected" : "Disconnected")
            </span>
        </div>
        <div class="stat-card">
            <span class="stat-label">KIS Broker</span>
            <span class="stat-value @(kisConnected ? "text-green" : "text-muted")">
                @(kisConnected ? "Connected" : "Not Connected")
            </span>
        </div>
    </div>

    <!-- Pipeline Logs -->
    <h4 class="section-title" style="margin-top:1rem">Recent Pipeline Runs</h4>
    @if (pipelineLogs.Any())
    {
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Step</th>
                        <th>Status</th>
                        <th>Duration</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in pipelineLogs)
                    {
                        <tr>
                            <td>@log.CreatedAt.ToString("MM/dd HH:mm")</td>
                            <td>@log.StepName</td>
                            <td>
                                <span class="status-chip status-@log.Status">@log.Status</span>
                            </td>
                            <td>@(log.ElapsedSec != null ? $"{log.ElapsedSec:F1}s" : "--")</td>
                            <td class="text-red">@(log.ErrorMsg ?? "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<SwingConfig> configs = new();
    private List<SwingPipelineLog> pipelineLogs = new();
    private Dictionary<string, string> editValues = new();
    private string? statusMsg;
    private bool engineOk;
    private bool dbOk;
    private bool kisConnected;
    private string tradingMode = "paper";

    // Trading Mode toggle
    private bool showModeConfirm;
    private bool modeChanging;
    private string targetMode = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var cfgTask = Db.GetAllConfigAsync();
            var logTask = Db.GetPipelineLogsAsync(10);
            var healthTask = CheckEngineHealth();
            dbOk = await Db.HealthCheckAsync();

            await Task.WhenAll(cfgTask, logTask, healthTask);

            configs = cfgTask.Result;
            pipelineLogs = logTask.Result;

            var mode = configs.FirstOrDefault(c => c.Key == "trading_mode");
            tradingMode = mode?.Value ?? "paper";
        }
        catch { }
    }

    private async Task CheckEngineHealth()
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/health");
            engineOk = true;
            kisConnected = resp.TryGetProperty("kis", out var k) && k.GetBoolean();
        }
        catch
        {
            engineOk = false;
        }
    }

    private void StartModeChange()
    {
        targetMode = tradingMode == "live" ? "paper" : "live";
        showModeConfirm = true;
    }

    private void CancelModeChange()
    {
        showModeConfirm = false;
    }

    private async Task ConfirmModeChange()
    {
        modeChanging = true;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var payload = new { mode = targetMode, confirm = true };
            var resp = await client.PostAsJsonAsync("/config/trading-mode", payload);
            if (resp.IsSuccessStatusCode)
            {
                tradingMode = targetMode;
                statusMsg = $"Trading mode changed to {targetMode.ToUpper()}";
                // Refresh config list
                configs = await Db.GetAllConfigAsync();
                await CheckEngineHealth();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                statusMsg = $"Mode change failed: {body}";
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            modeChanging = false;
            showModeConfirm = false;
        }
    }

    private async Task SaveConfig(string key)
    {
        if (!editValues.ContainsKey(key)) return;
        try
        {
            await Db.UpdateConfigAsync(key, editValues[key]);
            statusMsg = $"Updated '{key}' = '{editValues[key]}'";
            editValues.Remove(key);
            configs = await Db.GetAllConfigAsync();

            if (key == "trading_mode")
                tradingMode = editValues.GetValueOrDefault(key, "paper");
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
    }
}
