@page "/watchlist"
@attribute [Authorize]
@inject IHttpClientFactory HttpFactory
@inject SwingService Db
@inject IJSRuntime JS
@implements IDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Swing V4 - Watchlist</PageTitle>

<div class="page-header">
    <h3>My Watchlist</h3>
    <div style="display:flex; align-items:center; gap:0.5rem">
        @if (lastSparklineUpdate.HasValue)
        {
            <span class="text-muted" style="font-size:0.65rem; margin-right:0.25rem">
                <span class="material-symbols-outlined" style="font-size:12px; vertical-align:middle">update</span>
                @lastSparklineUpdate.Value.ToString("HH:mm:ss")
            </span>
        }
        <button class="btn-action" @onclick="AnalyzeAll" disabled="@analyzing">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">analytics</span>
            @(analyzing ? "Analyzing..." : "Analyze All")
        </button>
        <button class="btn-action btn-outline" @onclick="RunChartDebug" disabled="@debugRunning" title="Chart API 디버그">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">bug_report</span>
        </button>
        <button class="btn-action btn-outline" @onclick="LoadAll">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">refresh</span>
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMsg))
{
    <div class="alert-info" style="margin:0.5rem 0">@statusMsg</div>
}

<!-- ① Analysis Results (최상단) -->
@if (analysisResults.Any())
{
    @foreach (var r in analysisResults)
    {
        var sym = r.TryGetProperty("symbol", out var sv) ? sv.GetString() ?? "" : "";
        var dir = r.TryGetProperty("direction", out var dv) ? dv.GetString() ?? "NEUTRAL" : "NEUTRAL";
        var price = r.TryGetProperty("current_price", out var pv2) ? pv2.GetDouble() : 0;
        var pnl = r.TryGetProperty("pnl_pct", out var pnlv) && pnlv.ValueKind != System.Text.Json.JsonValueKind.Null ? (double?)pnlv.GetDouble() : null;
        var target = r.TryGetProperty("target_price", out var tv) ? tv.GetDouble() : 0;
        var stop = r.TryGetProperty("stop_price", out var stv) ? stv.GetDouble() : 0;
        var oscBuy = r.TryGetProperty("osc_buy", out var ob) ? ob.GetInt32() : 0;
        var oscSell = r.TryGetProperty("osc_sell", out var os2) ? os2.GetInt32() : 0;
        var oscNeutral = r.TryGetProperty("osc_neutral", out var on) ? on.GetInt32() : 0;
        var maBuy = r.TryGetProperty("ma_buy", out var mb) ? mb.GetInt32() : 0;
        var maSell = r.TryGetProperty("ma_sell", out var ms) ? ms.GetInt32() : 0;
        var totalBuy = r.TryGetProperty("total_buy", out var tb) ? tb.GetInt32() : 0;
        var totalSell = r.TryGetProperty("total_sell", out var ts) ? ts.GetInt32() : 0;
        var totalNeutral = r.TryGetProperty("total_neutral", out var tn) ? tn.GetInt32() : 0;
        var dirLabel = dir switch { "STRONG_BUY" => "Strong Buy", "STRONG_SELL" => "Strong Sell", "BUY" => "Buy", "SELL" => "Sell", _ => "Neutral" };
        var dirCss = dir.Contains("BUY") ? "summary-buy" : dir.Contains("SELL") ? "summary-sell" : "summary-neutral";
        var regime = r.TryGetProperty("regime", out var rv) ? rv.GetString() ?? "MIXED" : "MIXED";
        var volFactor = r.TryGetProperty("vol_factor", out var vfv) ? vfv.GetDouble() : 1.0;
        var wScore = r.TryGetProperty("weighted_score", out var wsv) ? wsv.GetDouble() : 0;
        var volRatio = r.TryGetProperty("vol_ratio", out var vrv) ? vrv.GetDouble() : 1.0;
        double catRsi2 = 0, catTrend = 0, catVol = 0, catRs = 0, catVolat = 0;
        if (r.TryGetProperty("category_scores", out var cs))
        {
            catRsi2 = cs.TryGetProperty("rsi2_reversion", out var cr2) ? cr2.GetDouble() : 0;
            catTrend = cs.TryGetProperty("trend", out var ct) ? ct.GetDouble() : 0;
            catVol = cs.TryGetProperty("volume", out var cv) ? cv.GetDouble() : 0;
            catRs = cs.TryGetProperty("rel_strength", out var crs) ? crs.GetDouble() : 0;
            catVolat = cs.TryGetProperty("volatility", out var cvl) ? cvl.GetDouble() : 0;
        }
        double wRsi2 = 0.35, wTrend = 0.25, wVol = 0.15, wRs = 0.15, wVolat = 0.10;
        if (r.TryGetProperty("category_weights", out var cw))
        {
            wRsi2 = cw.TryGetProperty("rsi2_reversion", out var cwr) ? cwr.GetDouble() : 0.35;
            wTrend = cw.TryGetProperty("trend", out var cwt) ? cwt.GetDouble() : 0.25;
            wVol = cw.TryGetProperty("volume", out var cwv) ? cwv.GetDouble() : 0.15;
            wRs = cw.TryGetProperty("rel_strength", out var cwrs) ? cwrs.GetDouble() : 0.15;
            wVolat = cw.TryGetProperty("volatility", out var cwvl) ? cwvl.GetDouble() : 0.10;
        }
        // Connors RSI(2) extra fields
        var rsi2Val = r.TryGetProperty("rsi2", out var r2v) ? r2v.GetDouble() : 50;
        var cumRsi2 = r.TryGetProperty("cum_rsi2", out var cr2v) ? cr2v.GetDouble() : 100;
        var connorsExit = r.TryGetProperty("connors_exit", out var cev) && (cev.ValueKind == System.Text.Json.JsonValueKind.True || (cev.ValueKind == System.Text.Json.JsonValueKind.String && cev.GetString() == "True"));
        var opexWeek = r.TryGetProperty("opex_week", out var oev) && (oev.ValueKind == System.Text.Json.JsonValueKind.True || (oev.ValueKind == System.Text.Json.JsonValueKind.String && oev.GetString() == "True"));
        var bbSqueeze = r.TryGetProperty("bb_squeeze", out var bsv) && (bsv.ValueKind == System.Text.Json.JsonValueKind.True || (bsv.ValueKind == System.Text.Json.JsonValueKind.String && bsv.GetString() == "True"));
        var relStr5d = r.TryGetProperty("rel_str_5d", out var rs5) ? rs5.GetDouble() : 0;
        var relStr20d = r.TryGetProperty("rel_str_20d", out var rs20) ? rs20.GetDouble() : 0;

        // 5-Layer TQM fields
        var compositeScore = r.TryGetProperty("composite_score", out var csv) ? csv.GetDouble() : 0;
        // Layer 1: Regime
        string l1Trend = "?"; double l1Vix = 0; bool l1Allowed = true; double l1Mom3m = 0;
        if (r.TryGetProperty("layer1_regime", out var l1j)) {
            l1Trend = l1j.TryGetProperty("market_trend", out var mt) ? mt.GetString() ?? "?" : "?";
            l1Vix = l1j.TryGetProperty("vix", out var vx) ? vx.GetDouble() : 0;
            l1Allowed = !l1j.TryGetProperty("entry_allowed", out var ea) || ea.ValueKind != System.Text.Json.JsonValueKind.False;
            l1Mom3m = l1j.TryGetProperty("momentum_3m", out var m3) ? m3.GetDouble() : 0;
        }
        // Layer 2: Ranking
        double l2Rs = 50; string l2Stage = "?"; double l2Mom6m = 0;
        if (r.TryGetProperty("layer2_ranking", out var l2j)) {
            l2Rs = l2j.TryGetProperty("rs_rating", out var rr) ? rr.GetDouble() : 50;
            l2Stage = l2j.TryGetProperty("stage", out var st) ? st.GetString() ?? "?" : "?";
            l2Mom6m = l2j.TryGetProperty("momentum_6m", out var m6) ? m6.GetDouble() : 0;
        }
        // Layer 3: Entry
        double l3Score = 50; bool l3SqFired = false; bool l3MomPos = false;
        if (r.TryGetProperty("layer3_entry", out var l3j)) {
            l3Score = l3j.TryGetProperty("score", out var s3) ? s3.GetDouble() : 50;
            l3SqFired = l3j.TryGetProperty("squeeze_fired", out var sf) && sf.ValueKind == System.Text.Json.JsonValueKind.True;
            l3MomPos = l3j.TryGetProperty("momentum_positive", out var mp) && mp.ValueKind == System.Text.Json.JsonValueKind.True;
        }
        // Layer 4: Sizing
        double l4Pct = 15;
        if (r.TryGetProperty("layer4_sizing", out var l4j)) {
            l4Pct = l4j.TryGetProperty("suggested_pct", out var sp) ? sp.GetDouble() : 15;
        }
        // Layer 5: Exit
        double l5Kama = 0; bool l5KamaExit = false;
        if (r.TryGetProperty("layer5_exit", out var l5j)) {
            l5Kama = l5j.TryGetProperty("kama", out var k5) ? k5.GetDouble() : 0;
            l5KamaExit = l5j.TryGetProperty("kama_exit", out var ke) && ke.ValueKind == System.Text.Json.JsonValueKind.True;
        }
        // Quality
        double qualScore = 50;
        if (r.TryGetProperty("quality", out var qj)) {
            qualScore = qj.TryGetProperty("score", out var qs) ? qs.GetDouble() : 50;
        }

        <div class="section-card analysis-card" style="margin-bottom:0.3rem">
            <!-- Level 1: Compact Header -->
            <div class="analysis-compact-header" @onclick="() => ToggleCard(sym)">
                <div style="display:flex; align-items:center; flex:1; min-width:0">
                    <span class="material-symbols-outlined collapse-chevron @(expandedCards.Contains(sym) ? "" : "collapsed")"
                          style="font-size:16px; width:20px; flex-shrink:0; transition:transform 0.2s">expand_more</span>
                    <a href="https://edition.cnn.com/markets/stocks/@sym" target="_blank" rel="noopener"
                       @onclick:stopPropagation="true"
                       class="wl-sym"
                       style="display:inline-block; width:58px; flex:0 0 58px; font-weight:700; font-size:1.05rem; color:var(--primary); text-decoration:none; white-space:nowrap; overflow:hidden"
                       title="CNN Markets — @sym">@sym</a>
                    @{  var compName = r.TryGetProperty("company_name", out var cn) ? cn.GetString() ?? "" : ""; }
                    <span class="wl-company" style="display:inline-block; width:100px; flex:0 0 100px; font-size:0.72rem; color:var(--text-secondary); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; margin-left:2px">@compName</span>
                    <span class="wl-price" style="display:inline-block; width:78px; flex:0 0 78px; text-align:right; font-size:0.88rem; font-weight:600; font-variant-numeric:tabular-nums; white-space:nowrap">$@price.ToString("F2")</span>
                    @if (pnl.HasValue)
                    {
                        <span class="wl-pnl" style="display:inline-block; width:65px; flex:0 0 65px; text-align:right; font-size:0.8rem; font-weight:600; font-variant-numeric:tabular-nums; white-space:nowrap; color:@(pnl > 0 ? "var(--accent-green,#22c55e)" : "var(--accent-red,#ef4444)")">
                            @(pnl > 0 ? "+" : "")@pnl.Value.ToString("F2")%
                        </span>
                    }
                    else
                    {
                        <span class="wl-pnl" style="display:inline-block; width:65px; flex:0 0 65px"></span>
                    }
                </div>
                <div class="compact-right">
                    <canvas id="spark-@sym" width="80" height="28"
                            style="vertical-align:middle; flex-shrink:0"></canvas>
                    <span class="compact-verdict @dirCss">@dirLabel</span>
                    <span class="compact-score" title="Composite Score (0-100)" style="font-weight:700; color:@(compositeScore >= 65 ? "var(--green)" : compositeScore <= 35 ? "var(--red)" : "var(--text-secondary)")">@compositeScore.ToString("F0")</span>
                    <span class="compact-score" style="color:var(--text-secondary); font-size:0.65rem">@(wScore >= 0 ? "+" : "")@wScore.ToString("F3")</span>
                </div>
            </div>

            <!-- Level 2: Summary Gauge + Category Breakdown -->
            @if (expandedCards.Contains(sym))
            {
                <div class="ind-header" style="padding-top:0.3rem">
                    <div></div>
                    <span class="text-muted" style="font-size:0.72rem">Target $@target.ToString("F2") / Stop $@stop.ToString("F2")</span>
                </div>

                <div class="wl-level2-row">
                    <!-- LEFT: Summary Gauge (50%) -->
                    <div class="wl-level2-left">
                        <div class="summary-gauge" style="margin:0">
                            <div class="gauge-sections">
                                <div class="gauge-section" style="flex:1">
                                    <div class="gauge-label">Oscillators</div>
                                    <div class="gauge-counts">
                                        <span class="text-green">@oscBuy</span> /
                                        <span class="text-muted">@oscNeutral</span> /
                                        <span class="text-red">@oscSell</span>
                                    </div>
                                </div>
                                <div class="gauge-section gauge-total" style="flex:1.8">
                                    <div class="gauge-label">Weighted Score</div>
                                    <div class="gauge-verdict gauge-verdict-main @dirCss" style="font-size:1rem">@dirLabel</div>
                                    <div style="font-size:0.78rem; font-weight:600; color:var(--text-primary); margin-top:0.1rem">
                                        @(wScore >= 0 ? "+" : "")@wScore.ToString("F3")
                                    </div>
                                    <div style="display:flex; gap:0.4rem; font-size:0.62rem; margin-top:0.15rem; justify-content:center">
                                        <span class="@(regime == "TRENDING" ? "text-green" : regime == "SIDEWAYS" ? "text-yellow" : "text-muted")" style="font-weight:600">@regime</span>
                                        <span class="text-muted">|</span>
                                        <span class="@(volFactor >= 1.0 ? "text-green" : "text-yellow")" style="font-weight:600">Vol ×@volRatio.ToString("F1")</span>
                                    </div>
                                </div>
                                <div class="gauge-section" style="flex:1">
                                    <div class="gauge-label">Moving Avgs</div>
                                    <div class="gauge-counts">
                                        <span class="text-green">@maBuy</span> /
                                        <span class="text-muted">0</span> /
                                        <span class="text-red">@maSell</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Connors RSI(2) Key Metrics -->
                            <div style="display:flex; gap:0.5rem; font-size:0.68rem; margin:0.2rem 0; justify-content:center; flex-wrap:wrap">
                                <span title="RSI(2) — Connors 핵심" style="font-weight:700; color:@(rsi2Val < 10 ? "var(--green)" : rsi2Val > 90 ? "var(--red)" : "var(--text-secondary)")">RSI(2): @rsi2Val.ToString("F0")</span>
                                <span title="2일 누적 RSI(2)" class="text-muted">CumRSI2: @cumRsi2.ToString("F0")</span>
                                <span title="QQQ 대비 5일 상대강도" class="@(relStr5d > 0 ? "text-green" : relStr5d < 0 ? "text-red" : "text-muted")">vs QQQ: @(relStr5d >= 0 ? "+" : "")@relStr5d.ToString("F1")%</span>
                                @if (connorsExit) { <span class="text-yellow" title="Connors Exit: Close > SMA(5)">EXIT</span> }
                                @if (opexWeek) { <span class="text-yellow" title="옵션만기 주간 — 매수 보류 권장">OPEX</span> }
                                @if (bbSqueeze) { <span class="text-green" title="Bollinger 스퀴즈 — 에너지 축적 중">SQUEEZE</span> }
                            </div>

                            <!-- 5-Layer TQM Signal Panel -->
                            <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:0.3rem; margin:0.3rem 0; padding:0.3rem; background:var(--s0); border-radius:6px; font-size:0.62rem">
                                <div style="text-align:center" title="Layer 1: 시장 레짐 (Faber SMA + VIX)">
                                    <div style="font-weight:700; color:var(--text-secondary); margin-bottom:0.1rem">REGIME</div>
                                    <div style="font-weight:700; color:@(l1Trend == "BULLISH" ? "var(--green)" : l1Trend == "BEARISH" ? "var(--red)" : "var(--yellow)")">
                                        @(l1Trend == "BULLISH" ? "Bull" : l1Trend == "BEARISH" ? "Bear" : l1Trend == "CAUTIOUS" ? "Caution" : "Weak")
                                    </div>
                                    <div class="text-muted">VIX @l1Vix.ToString("F0")</div>
                                </div>
                                <div style="text-align:center" title="Layer 2: RS Rating + Weinstein Stage">
                                    <div style="font-weight:700; color:var(--text-secondary); margin-bottom:0.1rem">RS / STAGE</div>
                                    <div style="font-weight:700; color:@(l2Rs >= 70 ? "var(--green)" : l2Rs <= 30 ? "var(--red)" : "var(--text-primary)")">RS @l2Rs.ToString("F0")</div>
                                    <div style="color:@(l2Stage == "STAGE_2" ? "var(--green)" : l2Stage == "STAGE_4" ? "var(--red)" : "var(--text-secondary)")">@(l2Stage.Replace("STAGE_", "S"))</div>
                                </div>
                                <div style="text-align:center" title="Layer 3: 진입 타이밍 (Squeeze + RSI2 + PEAD)">
                                    <div style="font-weight:700; color:var(--text-secondary); margin-bottom:0.1rem">TIMING</div>
                                    <div style="font-weight:700; color:@(l3Score >= 65 ? "var(--green)" : l3Score <= 35 ? "var(--red)" : "var(--text-primary)")">@l3Score.ToString("F0")/100</div>
                                    <div>
                                        @if (l3SqFired) { <span style="color:var(--green); font-weight:700">FIRED!</span> }
                                        else if (bbSqueeze) { <span style="color:var(--yellow)">Squeeze</span> }
                                        else { <span class="text-muted">—</span> }
                                    </div>
                                </div>
                                <div style="text-align:center" title="Quality Score (GP/Assets + ROE + Margin)">
                                    <div style="font-weight:700; color:var(--text-secondary); margin-bottom:0.1rem">QUALITY</div>
                                    <div style="font-weight:700; color:@(qualScore >= 65 ? "var(--green)" : qualScore <= 35 ? "var(--red)" : "var(--text-primary)")">@qualScore.ToString("F0")/100</div>
                                    <div class="text-muted">@l4Pct.ToString("F0")% size</div>
                                </div>
                                <div style="text-align:center" title="Layer 5: 매도 신호 (KAMA + ATR Stop)">
                                    <div style="font-weight:700; color:var(--text-secondary); margin-bottom:0.1rem">EXIT</div>
                                    @if (l5KamaExit) {
                                        <div style="font-weight:700; color:var(--red)">KAMA Exit</div>
                                    } else if (connorsExit) {
                                        <div style="font-weight:700; color:var(--yellow)">SMA5 Exit</div>
                                    } else {
                                        <div style="font-weight:700; color:var(--green)">Hold</div>
                                    }
                                    <div class="text-muted">K @l5Kama.ToString("F1")</div>
                                </div>
                            </div>

                            <div class="category-breakdown">
                                @{
                                    var cats = new (string Name, double Score, double Weight)[] {
                                        ("RSI(2)", catRsi2, wRsi2),
                                        ("Trend", catTrend, wTrend),
                                        ("Volume", catVol, wVol),
                                        ("Rel.Str", catRs, wRs),
                                        ("Volatility", catVolat, wVolat),
                                    };
                                }
                                @foreach (var c in cats)
                                {
                                    var pct = (int)Math.Round(Math.Abs(c.Score) * 50);
                                    var catCss = c.Score > 0.1 ? "cat-buy" : c.Score < -0.1 ? "cat-sell" : "cat-neutral";
                                    <div class="cat-row">
                                        <span class="cat-label">@c.Name <span class="text-muted">(@((int)(c.Weight*100))%)</span></span>
                                        <div class="cat-bar-track">
                                            <div class="cat-bar-center"></div>
                                            @if (c.Score >= 0)
                                            {
                                                <div class="cat-bar-fill cat-bar-buy" style="left:50%; width:@(pct)%"></div>
                                            }
                                            else
                                            {
                                                <div class="cat-bar-fill cat-bar-sell" style="right:50%; width:@(pct)%"></div>
                                            }
                                        </div>
                                        <span class="cat-val @catCss">@(c.Score >= 0 ? "+" : "")@c.Score.ToString("F2")</span>
                                    </div>
                                }
                            </div>

                            @{ var barBuyPct = totalBuy + totalSell > 0 ? (int)(100.0 * totalBuy / (totalBuy + totalSell + totalNeutral)) : 50; }
                            <div class="summary-bar">
                                <div class="summary-bar-buy" style="width:@(barBuyPct)%"></div>
                            </div>
                            <div class="summary-bar-labels">
                                <span class="text-green" style="font-size:0.7rem">Buy @totalBuy</span>
                                <span class="text-muted" style="font-size:0.7rem">Neutral @totalNeutral</span>
                                <span class="text-red" style="font-size:0.7rem">Sell @totalSell</span>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT: Chart with Period Selector (50%) -->
                    <div class="wl-level2-right">
                        <div class="chart-period-bar">
                            @foreach (var p in new[] { ("1D","1d"), ("5D","5d"), ("1M","1mo"), ("6M","6mo"), ("1Y","1y"), ("5Y","5y") })
                            {
                                var pVal = p.Item2;
                                var isActive = (selectedPeriod.GetValueOrDefault(sym, "1d") == pVal);
                                <button class="btn-period @(isActive ? "btn-period-active" : "")"
                                        @onclick="() => SwitchPeriod(sym, pVal)"
                                        @onclick:stopPropagation="true">@p.Item1</button>
                            }
                        </div>
                        @if (!intradayLoaded.Contains(sym))
                        {
                            <span class="text-muted" style="font-size:0.8rem; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%)">Loading...</span>
                        }
                        <canvas id="intraday-@sym" style="@(!intradayLoaded.Contains(sym) ? "display:none" : "")"></canvas>
                    </div>
                </div>

                <!-- Show/Hide Details toggle -->
                <div class="detail-toggle" @onclick="() => ToggleDetail(sym)" @onclick:stopPropagation="true">
                    <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle; transition:transform 0.2s; @(expandedDetails.Contains(sym) ? "" : "transform:rotate(-90deg)")">expand_more</span>
                    @(expandedDetails.Contains(sym) ? "Hide Details" : "Show Details")
                </div>

                <!-- Level 3: Oscillators + Moving Averages detail tables -->
                <div class="ind-two-col" style="@(expandedDetails.Contains(sym) ? "" : "display:none")">
                    <div class="ind-col">
                        <h5 class="ind-col-title">Oscillators</h5>
                        <table class="data-table ind-table">
                            <thead><tr><th>Name</th><th>Value</th><th>Action</th></tr></thead>
                            <tbody>
                                @if (r.TryGetProperty("indicators", out var indArr) && indArr.ValueKind == System.Text.Json.JsonValueKind.Array)
                                {
                                    @foreach (var ind in indArr.EnumerateArray())
                                    {
                                        var iname = ind.TryGetProperty("name", out var nv) ? nv.GetString() ?? "" : "";
                                        var ival = ind.TryGetProperty("value", out var vv) ? vv.GetDouble() : 0;
                                        var isig = ind.TryGetProperty("signal", out var sigv) ? sigv.GetString() ?? "NEUTRAL" : "NEUTRAL";
                                        <tr>
                                            <td>@iname</td>
                                            <td class="text-muted">@ival.ToString(iname.Contains("ATR") ? "F2" : iname.Contains("MACD") || iname.Contains("Bull") || iname.Contains("ROC") ? "F2" : "F1")</td>
                                            <td><span class="ind-signal @(isig == "BUY" ? "ind-buy" : isig == "SELL" ? "ind-sell" : "ind-neutral")">@isig</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="ind-col">
                        <h5 class="ind-col-title">Moving Averages</h5>
                        <table class="data-table ind-table">
                            <thead><tr><th>Name</th><th>Value</th><th>Action</th></tr></thead>
                            <tbody>
                                @if (r.TryGetProperty("moving_averages", out var maArr) && maArr.ValueKind == System.Text.Json.JsonValueKind.Array)
                                {
                                    @foreach (var ma in maArr.EnumerateArray())
                                    {
                                        var mname = ma.TryGetProperty("name", out var mnv) ? mnv.GetString() ?? "" : "";
                                        var mval = ma.TryGetProperty("value", out var mvv) ? mvv.GetDouble() : 0;
                                        var msig = ma.TryGetProperty("signal", out var msigv) ? msigv.GetString() ?? "NEUTRAL" : "NEUTRAL";
                                        <tr>
                                            <td>@mname</td>
                                            <td class="text-muted">@mval.ToString("F2")</td>
                                            <td><span class="ind-signal @(msig == "BUY" ? "ind-buy" : msig == "SELL" ? "ind-sell" : "ind-neutral")">@msig</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
    @if (!string.IsNullOrEmpty(analyzedAt))
    {
        <p class="text-muted" style="padding:0.5rem; font-size:0.72rem">Last analyzed: @analyzedAt</p>
    }
}
else
{
    <div class="section-card">
        <h4 class="section-title">Analysis Results</h4>
        <p class="text-muted" style="padding:1rem">
            No analysis results. Click "Analyze All" to run technical analysis.
        </p>
    </div>
}

<!-- ② Signal Log & Replay Backtest -->
<div class="section-card" style="margin-bottom:1rem; margin-top:1rem">
    <h4 class="section-title collapsible-title" @onclick="() => showBacktest = !showBacktest" style="cursor:pointer">
        <span class="material-symbols-outlined collapse-chevron @(showBacktest ? "" : "collapsed")"
              style="font-size:18px; vertical-align:middle; transition:transform 0.2s">expand_more</span>
        Signal Replay Backtest
    </h4>
    @if (showBacktest)
    {
        <!-- Signal Log Stats -->
        <div style="margin-top:0.5rem; padding:0.5rem; background:var(--s2); border-radius:6px; font-size:0.8rem">
            @if (logStats != null)
            {
                var logDays = logStats.Value.TryGetProperty("days", out var ld) ? ld.GetInt32() : 0;
                var logSyms = logStats.Value.TryGetProperty("symbols", out var ls) ? ls.GetInt32() : 0;
                var logFirst = logStats.Value.TryGetProperty("first_date", out var lf) ? lf.GetString() : "--";
                var logLast = logStats.Value.TryGetProperty("last_date", out var ll) ? ll.GetString() : "--";
                var logBuy = logStats.Value.TryGetProperty("buy_count", out var lb) ? lb.GetInt32() : 0;
                var logSell = logStats.Value.TryGetProperty("sell_count", out var lsl) ? lsl.GetInt32() : 0;
                var logNeutral = logStats.Value.TryGetProperty("neutral_count", out var ln) ? ln.GetInt32() : 0;
                <div style="display:flex; gap:1.5rem; flex-wrap:wrap; align-items:center">
                    <span><strong>Signal Log:</strong> @logDays days · @logSyms symbols</span>
                    <span class="text-muted">@logFirst ~ @logLast</span>
                    <span>
                        <span class="text-green">BUY @logBuy</span> ·
                        <span class="text-muted">NEUTRAL @logNeutral</span> ·
                        <span class="text-red">SELL @logSell</span>
                    </span>
                </div>
                @if (logDays < 5)
                {
                    <div style="margin-top:0.3rem; padding:0.3rem 0.5rem; background:rgba(249,115,22,0.12); border-radius:4px; color:#ffa502; font-size:0.75rem">
                        <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle">warning</span>
                        Signal logging started recently. Run "Analyze All" daily to accumulate data. Need 5+ trading days for meaningful backtest.
                    </div>
                }
            }
            else
            {
                <span class="text-muted">No signal logs yet. Run "Analyze All" to start logging signals.</span>
            }
        </div>

        <!-- Backtest Controls -->
        <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:flex-end; margin-top:0.5rem">
            <div>
                <label class="form-label">Capital ($)</label>
                <input type="number" class="form-input form-input-sm" @bind="btCapital" step="100" style="width:100px" />
            </div>
            <div>
                <label class="form-label">Position %</label>
                <input type="number" class="form-input form-input-sm" @bind="btPosPct" step="0.05" style="width:70px" />
            </div>
            <div>
                <label class="form-label">Max Pos</label>
                <input type="number" class="form-input form-input-sm" @bind="btMaxPos" min="1" max="10" style="width:60px" />
            </div>
            <div>
                <label class="form-label">Trail Stop %</label>
                <input type="number" class="form-input form-input-sm" @bind="btTrailStop" step="0.01" style="width:70px" />
            </div>
            <div>
                <label class="form-label">Max Hold</label>
                <input type="number" class="form-input form-input-sm" @bind="btMaxHold" style="width:60px" />
            </div>
            <button class="btn-sm btn-approve" @onclick="RunReplayBacktest" disabled="@btRunning">
                @(btRunning ? "Running..." : "Run Replay")
            </button>
        </div>

        @if (!string.IsNullOrEmpty(btStatus))
        {
            <div class="alert-info" style="margin:0.5rem 0; font-size:0.82rem">@btStatus</div>
        }

        @if (btResult != null && btResult.Value.TryGetProperty("status", out var bts) && bts.GetString() == "done")
        {
            <div style="font-size:0.72rem; color:var(--text-secondary); margin:0.3rem 0">
                @{
                    var btFirst = btResult.Value.TryGetProperty("first_date", out var bf) ? bf.GetString() : "";
                    var btLast = btResult.Value.TryGetProperty("last_date", out var bl) ? bl.GetString() : "";
                    var btDays = btResult.Value.TryGetProperty("days_logged", out var bd) ? bd.GetInt32() : 0;
                }
                Period: @btFirst ~ @btLast (@btDays trading days) — based on actual logged signals
            </div>

            <div class="stat-grid cols-4" style="margin-top:0.3rem">
                @{
                    var trr = btResult.Value.TryGetProperty("total_return", out var trv) ? trv.GetDouble() : 0;
                    var mdd = btResult.Value.TryGetProperty("max_drawdown", out var mdv) ? mdv.GetDouble() : 0;
                    var sharpe = btResult.Value.TryGetProperty("sharpe_ratio", out var shv) ? shv.GetDouble() : 0;
                    var winRate = btResult.Value.TryGetProperty("win_rate", out var wrv) ? wrv.GetDouble() : 0;
                    var pf = btResult.Value.TryGetProperty("profit_factor", out var pfv) ? pfv.GetDouble() : 0;
                    var totalTrades = btResult.Value.TryGetProperty("total_trades", out var ttv) ? ttv.GetInt32() : 0;
                    var avgHold = btResult.Value.TryGetProperty("avg_hold_days", out var ahv) ? ahv.GetDouble() : 0;
                    var finalVal = btResult.Value.TryGetProperty("final_value", out var fvv) ? fvv.GetDouble() : 0;
                }
                <div class="stat-card">
                    <div class="stat-label">TOTAL RETURN</div>
                    <div class="stat-value @(trr >= 0 ? "text-green" : "text-red")">@(trr >= 0 ? "+" : "")@trr.ToString("F1")%</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">MAX DRAWDOWN</div>
                    <div class="stat-value text-red">@mdd.ToString("F1")%</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">SHARPE</div>
                    <div class="stat-value">@sharpe.ToString("F2")</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">WIN RATE</div>
                    <div class="stat-value">@winRate.ToString("F1")%</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">PROFIT FACTOR</div>
                    <div class="stat-value">@pf.ToString("F2")</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">TRADES</div>
                    <div class="stat-value">@totalTrades</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">AVG HOLD</div>
                    <div class="stat-value">@avgHold.ToString("F0")d</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">FINAL VALUE</div>
                    <div class="stat-value @(finalVal >= btCapital ? "text-green" : "text-red")">$@finalVal.ToString("F0")</div>
                </div>
            </div>

            <!-- Signal Accuracy -->
            @if (btResult.Value.TryGetProperty("signal_accuracy", out var accEl) && accEl.ValueKind == System.Text.Json.JsonValueKind.Object)
            {
                <div style="margin-top:0.5rem; font-size:0.78rem">
                    <strong>Signal Accuracy:</strong>
                    @foreach (var prop in accEl.EnumerateObject())
                    {
                        var accTotal = prop.Value.TryGetProperty("total", out var at2) ? at2.GetInt32() : 0;
                        var accProfit = prop.Value.TryGetProperty("profitable", out var ap) ? ap.GetInt32() : 0;
                        var accPct = prop.Value.TryGetProperty("accuracy", out var ac) ? ac.GetDouble() : 0;
                        <span style="margin-left:0.75rem">
                            <strong>@prop.Name</strong>: @accProfit/@accTotal
                            (<span class="@(accPct >= 50 ? "text-green" : "text-red")">@accPct.ToString("F0")%</span>)
                        </span>
                    }
                </div>
            }

            <!-- Monthly Returns -->
            @if (btResult.Value.TryGetProperty("monthly_returns", out var monthlyEl) && monthlyEl.GetArrayLength() > 0)
            {
                <div style="margin-top:0.5rem">
                    <h5 class="section-title" style="font-size:0.82rem; margin-bottom:0.3rem">Monthly Returns</h5>
                    <div style="display:flex; gap:0.25rem; flex-wrap:wrap">
                        @foreach (var m in monthlyEl.EnumerateArray())
                        {
                            var mMonth = m.TryGetProperty("month", out var mm) ? mm.GetString() : "";
                            var mRet = m.TryGetProperty("return_pct", out var mr) ? mr.GetDouble() : 0;
                            <div style="padding:0.25rem 0.5rem; border-radius:4px; font-size:0.72rem; min-width:80px; text-align:center;
                                        background:@(mRet >= 0 ? "rgba(0,200,150,0.12)" : "rgba(239,68,68,0.12)");
                                        border:1px solid @(mRet >= 0 ? "rgba(0,200,150,0.3)" : "rgba(239,68,68,0.3)")">
                                <div class="text-muted">@mMonth</div>
                                <div class="@(mRet >= 0 ? "text-green" : "text-red")" style="font-weight:600">
                                    @(mRet >= 0 ? "+" : "")@mRet.ToString("F1")%
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Equity Curve Chart -->
            <div style="margin-top:0.5rem">
                <canvas id="wlBacktestChart" style="width:100%; height:200px"></canvas>
            </div>

            <!-- Trades Log -->
            @if (btResult.Value.TryGetProperty("trades_log", out var tlog) && tlog.GetArrayLength() > 0)
            {
                <div style="margin-top:0.5rem">
                    <h5 class="section-title" style="font-size:0.82rem; margin-bottom:0.3rem">Trade Log (@tlog.GetArrayLength())</h5>
                    <div class="table-responsive" style="max-height:300px; overflow-y:auto">
                        <table class="data-table" style="font-size:0.75rem">
                            <thead>
                                <tr>
                                    <th>Symbol</th>
                                    <th>Entry</th>
                                    <th>Exit</th>
                                    <th>Entry $</th>
                                    <th>Exit $</th>
                                    <th>Qty</th>
                                    <th>P&L</th>
                                    <th>P&L %</th>
                                    <th>Days</th>
                                    <th>Reason</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in tlog.EnumerateArray())
                                {
                                    var tPnl = t.TryGetProperty("pnl", out var tp) ? tp.GetDouble() : 0;
                                    var tPnlPct = t.TryGetProperty("pnl_pct", out var tpp) ? tpp.GetDouble() : 0;
                                    <tr>
                                        <td style="font-weight:600">@(t.TryGetProperty("symbol", out var ts) ? ts.GetString() : "")</td>
                                        <td class="text-muted">@(t.TryGetProperty("entry_date", out var ted) ? ted.GetString()?[5..] : "")</td>
                                        <td class="text-muted">@(t.TryGetProperty("exit_date", out var txd) ? txd.GetString()?[5..] : "")</td>
                                        <td>$@(t.TryGetProperty("entry_price", out var tep) ? tep.GetDouble().ToString("F2") : "--")</td>
                                        <td>$@(t.TryGetProperty("exit_price", out var txp) ? txp.GetDouble().ToString("F2") : "--")</td>
                                        <td>@(t.TryGetProperty("qty", out var tq) ? tq.GetInt32().ToString() : "--")</td>
                                        <td class="@(tPnl >= 0 ? "text-green" : "text-red")">@(tPnl >= 0 ? "+" : "")$@tPnl.ToString("F2")</td>
                                        <td class="@(tPnlPct >= 0 ? "text-green" : "text-red")">@(tPnlPct >= 0 ? "+" : "")@tPnlPct.ToString("F1")%</td>
                                        <td>@(t.TryGetProperty("hold_days", out var thd) ? thd.GetInt32().ToString() : "--")</td>
                                        <td class="text-muted" style="font-size:0.68rem">@(t.TryGetProperty("reason", out var trn) ? trn.GetString() : "")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }
</div>

<!-- ③ Add Symbol Form -->
<div class="section-card" style="margin-bottom:1rem; margin-top:1rem">
    <h4 class="section-title">Add Symbol</h4>
    <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:flex-end">
        <div>
            <label class="form-label">Symbol</label>
            <input type="text" class="form-input form-input-sm" @bind="newSymbol"
                   placeholder="AAPL" style="width:100px; text-transform:uppercase" />
        </div>
        <div>
            <label class="form-label">Company</label>
            <input type="text" class="form-input form-input-sm" @bind="newCompany"
                   placeholder="Apple Inc." style="width:160px" />
        </div>
        <div>
            <label class="form-label">Avg Cost ($)</label>
            <input type="number" class="form-input form-input-sm" @bind="newAvgCost"
                   step="0.01" style="width:100px" />
        </div>
        <div>
            <label class="form-label">Qty</label>
            <input type="number" class="form-input form-input-sm" @bind="newQty"
                   step="0.01" style="width:80px" />
        </div>
        <div>
            <label class="form-label">Notes</label>
            <input type="text" class="form-input form-input-sm" @bind="newNotes"
                   placeholder="memo" style="width:140px" />
        </div>
        <button class="btn-sm btn-approve" @onclick="AddSymbol" disabled="@adding">
            @(adding ? "Adding..." : "Add")
        </button>
    </div>
</div>

<!-- ④ Registered Symbols (접기/펼치기) -->
<div class="section-card" style="margin-bottom:1rem">
    <h4 class="section-title collapsible-title" @onclick="() => showRegistered = !showRegistered" style="cursor:pointer">
        <span class="material-symbols-outlined collapse-chevron @(showRegistered ? "" : "collapsed")"
              style="font-size:18px; vertical-align:middle; transition:transform 0.2s">
            expand_more
        </span>
        Registered Symbols (@watchlist.Count)
    </h4>
    @if (showRegistered)
    {
        @if (watchlist.Any())
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Symbol</th>
                            <th>Company</th>
                            <th>Avg Cost</th>
                            <th>Qty</th>
                            <th>Notes</th>
                            <th>Added</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var w in watchlist)
                        {
                            <tr>
                                <td style="font-weight:700"><a href="https://edition.cnn.com/markets/stocks/@w.Symbol" target="_blank" rel="noopener" style="color:var(--primary); text-decoration:none">@w.Symbol</a></td>
                                <td class="text-muted">@(w.CompanyName ?? "")</td>
                                <td>@(w.AvgCost > 0 ? $"${w.AvgCost:F2}" : "--")</td>
                                <td>@(w.Qty > 0 ? w.Qty.ToString("F2") : "--")</td>
                                <td class="text-muted">@(w.Notes ?? "")</td>
                                <td class="text-muted">@w.AddedAt.ToString("MM/dd")</td>
                                <td>
                                    <button class="btn-sm btn-reject" @onclick="() => RemoveSymbol(w.Symbol)">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted" style="padding:1rem">No symbols registered. Add symbols above.</p>
        }
    }
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- ④ Market Sector Heatmap -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div class="section-card" style="margin-top:1.5rem">
    @if (drilldownEtf == null)
    {
        <h4 class="section-title collapsible-title" @onclick="() => showHeatmap = !showHeatmap" style="cursor:pointer">
            <span class="material-symbols-outlined collapse-chevron @(showHeatmap ? "" : "collapsed")"
                  style="font-size:20px">chevron_right</span>
            <span class="material-symbols-outlined" style="font-size:18px; vertical-align:middle">grid_view</span>
            US Market Sector Heatmap
        </h4>
    }
    else
    {
        <h4 class="section-title" style="display:flex; align-items:center; gap:0.5rem">
            <span class="material-symbols-outlined" style="font-size:18px; vertical-align:middle; cursor:pointer" @onclick="() => drilldownEtf = null">arrow_back</span>
            <span>@drilldownEtf @drilldownSectorName</span>
            @if (drilldownStocks.Any())
            {
                <span class="text-muted" style="font-weight:400; font-size:0.75rem">
                    상승 @drilldownStocks.Count(s => s.ChangePct > 0) · 하락 @drilldownStocks.Count(s => s.ChangePct < 0)
                </span>
            }
            <button class="btn-action btn-outline" style="padding:3px 10px; font-size:0.78rem; margin-left:auto" @onclick="() => drilldownEtf = null">← 돌아가기</button>
        </h4>
    }

    @if (showHeatmap || drilldownEtf != null)
    {
        @if (heatmapLoading)
        {
            <p class="text-muted">Loading market data...</p>
        }
        else if (sectorData.Any())
        {
            @if (drilldownEtf == null)
            {
                <!-- Index Summary Bar -->
                <div style="display:flex; gap:0.6rem; margin-bottom:0.8rem; flex-wrap:wrap">
                    @foreach (var idx in indexData)
                    {
                        var idxColor = idx.ChangePct >= 0 ? "var(--accent-green, #22c55e)" : "var(--accent-red, #ef4444)";
                        <div style="background:var(--s3, #1e293b); border-radius:6px; padding:0.35rem 0.7rem; border-left:3px solid @idxColor">
                            <span style="font-weight:700; font-size:0.82rem">@idx.Name</span>
                            <span style="color:@idxColor; font-weight:600; margin-left:0.3rem; font-size:0.82rem">
                                @(idx.ChangePct >= 0 ? "+" : "")@idx.ChangePct.ToString("F2")%
                            </span>
                        </div>
                    }
                </div>

                <!-- Sector Treemap -->
                <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:4px; min-height:180px">
                    @foreach (var s in sectorData.OrderByDescending(x => x.Weight))
                    {
                        var intensity = Math.Min(Math.Abs(s.ChangePct) / 3.0, 1.0);
                        var bgColor = s.ChangePct >= 0
                            ? $"rgba(34,197,94,{(0.15 + intensity * 0.55):F2})"
                            : $"rgba(239,68,68,{(0.15 + intensity * 0.55):F2})";
                        var textColor = intensity > 0.4 ? "#fff" : "#e2e8f0";
                        var gridStyle = s.Weight >= 10
                            ? "grid-column:span 2; grid-row:span 2; min-height:140px"
                            : (s.Weight >= 7 ? "grid-column:span 2; min-height:70px" : "min-height:70px");
                        var symSize = s.Weight >= 10 ? "1.1rem" : "0.9rem";
                        var pctSize = s.Weight >= 10 ? "1.35rem" : "1.05rem";

                        <div style="@gridStyle; background:@bgColor; color:@textColor; border-radius:6px; padding:0.6rem; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center; cursor:pointer; transition:transform 0.15s"
                             title="Click to drill down — @s.Symbol (@s.NameEn)"
                             @onclick="() => ToggleDrilldown(s.Symbol)">
                            <div style="font-weight:700; font-size:@symSize">@s.Symbol</div>
                            <div style="font-size:0.7rem; opacity:0.85; margin:2px 0">@s.Name</div>
                            <div style="font-weight:700; font-size:@pctSize">@(s.ChangePct >= 0 ? "+" : "")@s.ChangePct.ToString("F2")%</div>
                        </div>
                    }
                </div>

                <!-- Advance / Decline -->
                <div style="display:flex; gap:1rem; margin-top:0.5rem; font-size:0.75rem; align-items:center">
                    <span>
                        <span style="color:var(--accent-green, #22c55e)">● 상승 @sectorData.Count(s => s.ChangePct > 0)</span>
                        &nbsp;
                        <span style="color:var(--text-secondary)">● 보합 @sectorData.Count(s => s.ChangePct == 0)</span>
                        &nbsp;
                        <span style="color:var(--accent-red, #ef4444)">● 하락 @sectorData.Count(s => s.ChangePct < 0)</span>
                    </span>
                    <span class="text-muted" style="margin-left:auto">@heatmapUpdatedAt</span>
                </div>
            }
            else
            {
                <!-- Drilldown: Sector Holdings (in-place) -->
                @if (drilldownLoading)
                {
                    <p class="text-muted" style="font-size:0.8rem">Loading @drilldownEtf holdings...</p>
                }
                else if (drilldownStocks.Any())
                {
                    <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:3px; min-height:180px">
                        @foreach (var st in drilldownStocks.OrderByDescending(x => x.Weight))
                        {
                            var stIntensity = Math.Min(Math.Abs(st.ChangePct) / 3.0, 1.0);
                            var stBg = st.ChangePct >= 0
                                ? $"rgba(34,197,94,{(0.15 + stIntensity * 0.55):F2})"
                                : $"rgba(239,68,68,{(0.15 + stIntensity * 0.55):F2})";
                            var stTxt = stIntensity > 0.4 ? "#fff" : "#e2e8f0";
                            var stSpan = st.Weight >= 15
                                ? "grid-column:span 2; grid-row:span 2; min-height:100px"
                                : (st.Weight >= 8 ? "grid-column:span 2; min-height:55px" : "min-height:55px");

                            <div style="@stSpan; background:@stBg; color:@stTxt; border-radius:5px; padding:0.4rem; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center"
                                 title="@st.Name — $@st.Price (@st.Weight%)">
                                <div style="font-weight:700; font-size:0.82rem">@st.Symbol</div>
                                <div style="font-size:0.62rem; opacity:0.8">@st.Name</div>
                                <div style="font-weight:700; font-size:0.9rem">@(st.ChangePct >= 0 ? "+" : "")@st.ChangePct.ToString("F2")%</div>
                            </div>
                        }
                    </div>
                }
            }
        }
        else
        {
            <p class="text-muted">No market data available.</p>
        }
    }
</div>

<!-- Chart Debug Popup -->
@if (debugVisible)
{
    <div class="modal-overlay" @onclick="() => debugVisible = false">
        <div class="modal-panel" @onclick:stopPropagation="true" style="max-width:720px; width:95vw; max-height:85vh; overflow-y:auto">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem">
                <h4 style="margin:0; font-size:0.95rem">
                    <span class="material-symbols-outlined" style="font-size:18px; vertical-align:middle; color:var(--accent-yellow,#eab308)">bug_report</span>
                    Chart API Debug
                </h4>
                <button class="btn-icon" @onclick="() => debugVisible = false">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <!-- Server Time -->
            <div style="background:var(--bg-secondary); border-radius:6px; padding:0.5rem 0.75rem; margin-bottom:0.75rem; font-size:0.75rem">
                <div style="display:flex; gap:1.5rem; flex-wrap:wrap">
                    <span><b>Server KST:</b> @debugServerKst</span>
                    <span><b>US Eastern:</b> @debugServerEt</span>
                    <span><b>Market:</b> <span style="color:@(debugMarketStatus == "OPEN" ? "#22c55e" : debugMarketStatus == "PRE" ? "#06b6d4" : debugMarketStatus == "POST" ? "#f97316" : "#ef4444")">@debugMarketStatus</span></span>
                </div>
            </div>

            <!-- Per-Symbol Results -->
            @foreach (var d in debugResults)
            {
                var dateMatch = d.DataDate == d.TodayEt;
                var hasPoints = d.PointCount > 0;
                var statusColor = hasPoints && dateMatch ? "#22c55e" : hasPoints ? "#eab308" : "#ef4444";
                var statusIcon = hasPoints && dateMatch ? "check_circle" : hasPoints ? "warning" : "error";
                <div style="background:var(--bg-secondary); border-radius:6px; padding:0.5rem 0.75rem; margin-bottom:0.4rem; border-left:3px solid @statusColor">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.3rem">
                        <span class="material-symbols-outlined" style="font-size:16px; color:@statusColor">@statusIcon</span>
                        <b style="font-size:0.82rem">@d.Symbol</b>
                        <span class="text-muted" style="font-size:0.7rem">@d.PointCount points</span>
                        @if (d.ElapsedMs > 0)
                        {
                            <span class="text-muted" style="font-size:0.65rem">(@(d.ElapsedMs)ms)</span>
                        }
                    </div>
                    <div style="font-size:0.7rem; display:flex; flex-wrap:wrap; gap:0.75rem">
                        <span>data_date: <b style="color:@(dateMatch ? "#22c55e" : "#ef4444")">@(d.DataDate ?? "null")</b></span>
                        <span>today_et: <b>@(d.TodayEt ?? "?")</b></span>
                        <span>prev_close: <b>@(d.PrevClose?.ToString("F2") ?? "null")</b></span>
                        @if (d.PointCount > 0)
                        {
                            <span>range: <b>@d.FirstTime</b> → <b>@d.LastTime</b></span>
                        }
                    </div>
                    @if (d.PointCount > 0)
                    {
                        <div style="font-size:0.68rem; margin-top:0.2rem; display:flex; gap:0.75rem">
                            <span style="color:#06b6d4">Pre: @d.PreCount</span>
                            <span style="color:#22c55e">Regular: @d.RegularCount</span>
                            <span style="color:#f97316">Post: @d.PostCount</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(d.Error))
                    {
                        <div style="font-size:0.7rem; color:#ef4444; margin-top:0.2rem">Error: @d.Error</div>
                    }
                </div>
            }

            @if (!debugResults.Any() && debugRunning)
            {
                <div class="text-muted" style="text-align:center; padding:1rem">Fetching chart data for all symbols...</div>
            }

            <!-- Diagnosis -->
            @if (debugResults.Any())
            {
                var stale = debugResults.Where(d => d.DataDate != d.TodayEt && d.PointCount > 0).ToList();
                var failed = debugResults.Where(d => d.PointCount == 0).ToList();
                var ok = debugResults.Where(d => d.DataDate == d.TodayEt && d.PointCount > 0).ToList();

                <div style="margin-top:0.75rem; padding:0.6rem 0.75rem; background:var(--s2); border-radius:6px; font-size:0.75rem">
                    <div style="font-weight:600; margin-bottom:0.3rem">
                        <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle">diagnosis</span>
                        진단 결과
                    </div>
                    @if (ok.Count == debugResults.Count)
                    {
                        <div style="color:#22c55e">모든 종목 오늘(@(debugResults.First().TodayEt)) 데이터 정상 수신</div>
                    }
                    else
                    {
                        @if (stale.Any())
                        {
                            <div style="color:#eab308; margin-bottom:0.2rem">
                                <b>과거 데이터 반환 (@(stale.Count)개):</b> @string.Join(", ", stale.Select(s => $"{s.Symbol}({s.DataDate})"))
                                <br/>→ yfinance period=2d에 오늘 데이터 미포함 (프리마켓 전 또는 휴장일)
                            </div>
                        }
                        @if (failed.Any())
                        {
                            <div style="color:#ef4444; margin-bottom:0.2rem">
                                <b>데이터 없음 (@(failed.Count)개):</b> @string.Join(", ", failed.Select(s => s.Symbol))
                                <br/>→ yfinance 응답 빈 배열 (티커 오류 또는 네트워크 이슈)
                            </div>
                        }
                        @if (ok.Any())
                        {
                            <div style="color:#22c55e">정상: @string.Join(", ", ok.Select(s => s.Symbol))</div>
                        }
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private List<WatchlistItem> watchlist = new();
    private List<System.Text.Json.JsonElement> analysisResults = new();
    private string? statusMsg;
    private string? analyzedAt;
    private bool analyzing;
    private CancellationTokenSource _cts = new();
    private bool adding;
    private bool showRegistered = false;
    private bool showBacktest = false;
    private bool showHeatmap = true;
    private HashSet<string> expandedCards = new();
    private HashSet<string> expandedDetails = new();
    private Dictionary<string, string> selectedPeriod = new();

    // Chart Debug
    private bool debugVisible;
    private bool debugRunning;
    private string? debugServerKst;
    private string? debugServerEt;
    private string? debugMarketStatus;
    private List<ChartDebugResult> debugResults = new();
    private record ChartDebugResult(
        string Symbol, int PointCount, string? DataDate, string? TodayEt,
        double? PrevClose, string? FirstTime, string? LastTime,
        int PreCount, int RegularCount, int PostCount,
        long ElapsedMs, string? Error);

    // Market Heatmap
    private bool heatmapLoading = false;
    private List<SectorItem> sectorData = new();
    private List<IndexItem> indexData = new();
    private string? heatmapUpdatedAt;
    private record SectorItem(string Symbol, string Name, string NameEn, double ChangePct, int Weight);
    private record IndexItem(string Symbol, string Name, double ChangePct);

    // Drilldown
    private string? drilldownEtf;
    private string? drilldownSectorName;
    private bool drilldownLoading;
    private List<StockItem> drilldownStocks = new();
    private record StockItem(string Symbol, string Name, int Weight, double ChangePct, double Price);

    // Replay Backtest
    private double btCapital = 1000;
    private double btPosPct = 0.20;
    private int btMaxPos = 3;
    private double btTrailStop = 0.05;
    private int btMaxHold = 30;
    private bool btRunning = false;
    private string? btStatus;
    private System.Text.Json.JsonElement? btResult;
    private System.Text.Json.JsonElement? logStats;

    private async Task ToggleCard(string sym)
    {
        if (expandedCards.Contains(sym))
        {
            expandedCards.Remove(sym);
            intradayLoaded.Remove(sym);
        }
        else
        {
            expandedCards.Add(sym);
            intradayLoaded.Remove(sym);
            StateHasChanged();
            await Task.Delay(200);
            await FetchAndRenderChart(sym, selectedPeriod.GetValueOrDefault(sym, "1d"));
        }
    }

    private async Task SwitchPeriod(string sym, string period)
    {
        selectedPeriod[sym] = period;
        intradayLoaded.Remove(sym);
        StateHasChanged();
        await Task.Delay(100);
        await FetchAndRenderChart(sym, period);
    }

    private void ToggleDetail(string sym)
    {
        if (!expandedDetails.Remove(sym))
            expandedDetails.Add(sym);
    }

    // Add form
    private string newSymbol = "";
    private string newCompany = "";
    private double newAvgCost;
    private double newQty;
    private string newNotes = "";

    private bool sparklineRendered;
    private System.Threading.Timer? _autoRefreshTimer;
    private DateTime? lastSparklineUpdate;

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
        // 페이지 진입 시 실행 중인 분석 감지 → 자동 폴링 재개
        await DetectAndResumeAnalysis();
        // 60초마다 sparkline + 확장된 차트 자동 갱신
        _autoRefreshTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await RefreshAllCharts();
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    /// <summary>분석 상태가 running이면 폴링 재개</summary>
    private async Task DetectAndResumeAnalysis()
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/watchlist/analysis");
            var status = resp.TryGetProperty("status", out var st) ? st.GetString() : null;
            if (status == "running")
            {
                analyzing = true;
                statusMsg = "Analysis is running... (resumed tracking)";
                StateHasChanged();
                _ = Task.Run(async () =>
                {
                    try { await PollAnalysisUntilDone(); }
                    finally
                    {
                        analyzing = false;
                        await InvokeAsync(async () =>
                        {
                            await LoadAnalysis();
                            statusMsg = $"Analysis complete: {analysisResults.Count} symbols analyzed";
                            StateHasChanged();
                        });
                    }
                });
            }
        }
        catch { }
    }

    /// <summary>분석 완료까지 폴링 (CancellationToken 지원)</summary>
    private async Task PollAnalysisUntilDone()
    {
        var token = _cts.Token;
        var client = HttpFactory.CreateClient("Engine");
        for (int i = 0; i < 40; i++) // 최대 ~2분 (40 x 3s)
        {
            try { await Task.Delay(3000, token); } catch (TaskCanceledException) { return; }
            if (token.IsCancellationRequested) return;
            try
            {
                var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/watchlist/analysis");
                var status = resp.TryGetProperty("status", out var st) ? st.GetString() : null;
                if (status == "done") return;
                if (status != "running") return; // error or unknown
            }
            catch { }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!sparklineRendered && analysisResults.Any())
        {
            sparklineRendered = true;
            await Task.Delay(500);
            await RenderAllSparklines();
        }
    }

    private async Task RenderAllSparklines()
    {
        // 모든 sparkline을 병렬로 동시 렌더링 (순차 → 병렬)
        var tasks = analysisResults
            .Select(r => r.TryGetProperty("symbol", out var sv) ? sv.GetString() ?? "" : "")
            .Where(sym => !string.IsNullOrEmpty(sym))
            .Select(sym => FetchAndRenderSparkline(sym))
            .ToList();
        await Task.WhenAll(tasks);
        lastSparklineUpdate = DateTime.Now;
    }

    /// <summary>타이머에 의한 자동 갱신: sparkline + 확장된 intraday 차트</summary>
    private async Task RefreshAllCharts()
    {
        // Sparkline 전체 병렬 갱신
        var sparkTasks = analysisResults
            .Select(r => r.TryGetProperty("symbol", out var sv) ? sv.GetString() ?? "" : "")
            .Where(sym => !string.IsNullOrEmpty(sym))
            .Select(sym => FetchAndRenderSparkline(sym))
            .ToList();
        await Task.WhenAll(sparkTasks);
        lastSparklineUpdate = DateTime.Now;

        // 확장된 카드의 intraday 차트도 병렬 갱신
        var chartTasks = expandedCards.ToList()
            .Select(sym => FetchAndRenderChart(sym, selectedPeriod.GetValueOrDefault(sym, "1d")))
            .ToList();
        await Task.WhenAll(chartTasks);
    }

    private async Task FetchAndRenderSparkline(string sym)
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            client.Timeout = TimeSpan.FromSeconds(15);
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>($"/watchlist/chart/{sym}?period=1d");
            if (resp.TryGetProperty("points", out var pts) && pts.GetArrayLength() > 0)
            {
                var prices = pts.EnumerateArray()
                    .Select(p => p.GetProperty("price").GetDouble()).ToArray();
                await JS.InvokeVoidAsync("chartHelper.createSparkline", $"spark-{sym}", prices);
            }
        }
        catch { }
    }

    private async Task LoadAll()
    {
        statusMsg = null;
        try
        {
            watchlist = await Db.GetWatchlistAsync();
            await LoadAnalysis();
            await LoadSignalLogStats();
            await LoadMarketOverview();
            // Reset sparkline flag so OnAfterRenderAsync re-renders them
            sparklineRendered = false;
        }
        catch (Exception ex)
        {
            statusMsg = $"Load error: {ex.Message}";
        }
    }

    private async Task LoadMarketOverview()
    {
        heatmapLoading = true;
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/market/overview");

            sectorData.Clear();
            indexData.Clear();

            if (resp.TryGetProperty("sectors", out var sectors))
            {
                foreach (var s in sectors.EnumerateArray())
                {
                    sectorData.Add(new SectorItem(
                        s.GetProperty("symbol").GetString() ?? "",
                        s.GetProperty("name").GetString() ?? "",
                        s.GetProperty("name_en").GetString() ?? "",
                        s.GetProperty("change_pct").GetDouble(),
                        s.GetProperty("weight").GetInt32()
                    ));
                }
            }
            if (resp.TryGetProperty("indices", out var indices))
            {
                foreach (var idx in indices.EnumerateArray())
                {
                    indexData.Add(new IndexItem(
                        idx.GetProperty("symbol").GetString() ?? "",
                        idx.GetProperty("name").GetString() ?? "",
                        idx.GetProperty("change_pct").GetDouble()
                    ));
                }
            }
            if (resp.TryGetProperty("updated_at", out var ua))
                heatmapUpdatedAt = ua.GetString()?[..16]?.Replace("T", " ");
        }
        catch { }
        finally { heatmapLoading = false; }
    }

    private async Task ToggleDrilldown(string etfSymbol)
    {
        if (drilldownEtf == etfSymbol)
        {
            drilldownEtf = null;
            return;
        }
        drilldownEtf = etfSymbol;
        drilldownSectorName = sectorData.FirstOrDefault(s => s.Symbol == etfSymbol)?.Name ?? etfSymbol;
        drilldownLoading = true;
        drilldownStocks.Clear();
        StateHasChanged();

        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>($"/market/sector/{etfSymbol}");
            if (resp.TryGetProperty("stocks", out var stocks))
            {
                foreach (var st in stocks.EnumerateArray())
                {
                    drilldownStocks.Add(new StockItem(
                        st.GetProperty("symbol").GetString() ?? "",
                        st.GetProperty("name").GetString() ?? "",
                        st.GetProperty("weight").GetInt32(),
                        st.GetProperty("change_pct").GetDouble(),
                        st.GetProperty("price").GetDouble()
                    ));
                }
            }
        }
        catch { }
        finally { drilldownLoading = false; }
    }

    private async Task LoadSignalLogStats()
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/watchlist/signal-log/stats");
            var total = resp.TryGetProperty("total", out var t) ? t.GetInt32() : 0;
            logStats = total > 0 ? resp : null;
        }
        catch { logStats = null; }
    }

    private async Task LoadAnalysis()
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.GetAsync("/watchlist/analysis?refresh_price=true");
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                analysisResults.Clear();
                if (json.TryGetProperty("results", out var arr))
                {
                    foreach (var item in arr.EnumerateArray())
                        analysisResults.Add(item);
                }
                if (json.TryGetProperty("analyzed_at", out var at))
                    analyzedAt = at.GetString();
            }
            else
            {
                statusMsg = $"Analysis load failed: {resp.StatusCode}";
            }
        }
        catch (Exception ex) { statusMsg = $"Analysis error: {ex.Message}"; }
    }

    private async Task AddSymbol()
    {
        if (string.IsNullOrWhiteSpace(newSymbol)) return;
        adding = true;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var payload = new
            {
                symbol = newSymbol.Trim().ToUpper(),
                company_name = newCompany.Trim(),
                avg_cost = newAvgCost,
                qty = newQty,
                notes = newNotes.Trim()
            };
            var resp = await client.PostAsJsonAsync("/watchlist", payload);
            if (resp.IsSuccessStatusCode)
            {
                statusMsg = $"Added {newSymbol.ToUpper()}";
                newSymbol = ""; newCompany = ""; newAvgCost = 0; newQty = 0; newNotes = "";
                watchlist = await Db.GetWatchlistAsync();
            }
            else
            {
                statusMsg = $"Add failed: {await resp.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex) { statusMsg = $"Error: {ex.Message}"; }
        finally { adding = false; }
    }

    private async Task RemoveSymbol(string symbol)
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.DeleteAsync($"/watchlist/{symbol}");
            if (resp.IsSuccessStatusCode)
            {
                watchlist = await Db.GetWatchlistAsync();
                statusMsg = $"Removed {symbol}";
            }
        }
        catch (Exception ex) { statusMsg = $"Error: {ex.Message}"; }
    }

    private async Task AnalyzeAll()
    {
        if (!watchlist.Any())
        {
            statusMsg = "Add symbols first";
            return;
        }
        analyzing = true;
        statusMsg = "Running analysis... this takes ~30 seconds";
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            client.Timeout = TimeSpan.FromSeconds(120);
            await client.PostAsync("/watchlist/analyze", null);
            if (_cts.IsCancellationRequested) return;

            await PollAnalysisUntilDone();
            if (_cts.IsCancellationRequested) return;

            await LoadAnalysis();
            statusMsg = $"Analysis complete: {analysisResults.Count} symbols analyzed";
        }
        catch (Exception ex)
        {
            if (!_cts.IsCancellationRequested)
                statusMsg = $"Error: {ex.Message}";
        }
        finally { analyzing = false; }
    }

    private async Task RunReplayBacktest()
    {
        btRunning = true;
        btStatus = "Running replay backtest on logged signals...";
        btResult = null;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            client.Timeout = TimeSpan.FromSeconds(120);
            var payload = new
            {
                initial_capital = btCapital,
                position_pct = btPosPct,
                max_positions = btMaxPos,
                trailing_stop_pct = btTrailStop,
                max_hold_days = btMaxHold,
            };
            var postResp = await client.PostAsJsonAsync("/watchlist/replay-backtest", payload);
            var postJson = await postResp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            if (postJson.TryGetProperty("status", out var errSt) && errSt.GetString() == "error")
            {
                btStatus = postJson.TryGetProperty("message", out var msg) ? msg.GetString() : "Error";
                return;
            }

            // Poll for results
            for (int i = 0; i < 40; i++)
            {
                await Task.Delay(2000);
                var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/watchlist/replay-backtest");
                if (resp.TryGetProperty("status", out var st) && st.GetString() == "done")
                {
                    btResult = resp;
                    btStatus = null;
                    StateHasChanged();
                    await RenderBacktestChart();
                    return;
                }
            }
            btStatus = "Backtest timed out. Try again.";
        }
        catch (Exception ex) { btStatus = $"Error: {ex.Message}"; }
        finally { btRunning = false; }
    }

    private HashSet<string> intradayLoaded = new();

    private async Task FetchAndRenderChart(string sym, string period = "1d")
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            client.Timeout = TimeSpan.FromSeconds(30);
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>($"/watchlist/chart/{sym}?period={period}");
            if (resp.TryGetProperty("points", out var pts) && pts.GetArrayLength() > 0)
            {
                var labels = pts.EnumerateArray()
                    .Select(p => p.GetProperty("time").GetString() ?? "").ToArray();
                var prices = pts.EnumerateArray()
                    .Select(p => p.GetProperty("price").GetDouble()).ToArray();

                intradayLoaded.Add(sym);
                StateHasChanged();
                await Task.Delay(50);

                if (period == "1d")
                {
                    var sessions = pts.EnumerateArray()
                        .Select(p => p.TryGetProperty("session", out var s) ? s.GetString() ?? "regular" : "regular").ToArray();
                    double? prevClose = resp.TryGetProperty("prev_close", out var pc) && pc.ValueKind != System.Text.Json.JsonValueKind.Null
                        ? pc.GetDouble() : null;
                    await JS.InvokeVoidAsync("chartHelper.createIntraday",
                        $"intraday-{sym}", labels, prices, sessions, prevClose);
                }
                else
                {
                    double? prevClose = resp.TryGetProperty("prev_close", out var pc2) && pc2.ValueKind != System.Text.Json.JsonValueKind.Null
                        ? pc2.GetDouble() : null;
                    await JS.InvokeVoidAsync("chartHelper.createPeriodChart",
                        $"intraday-{sym}", labels, prices, prevClose);
                }
            }
            else
            {
                intradayLoaded.Add(sym);
                StateHasChanged();
            }
        }
        catch
        {
            intradayLoaded.Add(sym);
            StateHasChanged();
        }
    }

    private async Task RenderBacktestChart()
    {
        if (btResult == null) return;
        try
        {
            if (btResult.Value.TryGetProperty("equity_curve", out var ec) && ec.GetArrayLength() > 0)
            {
                var labels = ec.EnumerateArray().Select(e =>
                    e.TryGetProperty("date", out var d) ? d.GetString() ?? "" : "").ToArray();
                var values = ec.EnumerateArray().Select(e =>
                    e.TryGetProperty("value", out var v) ? v.GetDouble() : 0).ToArray();
                await JS.InvokeVoidAsync("chartHelper.createLine", "wlBacktestChart", labels, values,
                    "Equity ($)", "rgba(25,127,230,1)", "rgba(25,127,230,0.1)");
            }
        }
        catch { }
    }

    private async Task RunChartDebug()
    {
        debugRunning = true;
        debugVisible = true;
        debugResults.Clear();
        debugServerKst = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
        debugServerEt = null;
        debugMarketStatus = "...";
        StateHasChanged();

        try
        {
            var client = HttpFactory.CreateClient("Engine");
            client.Timeout = TimeSpan.FromSeconds(30);

            // 서버 시간 + 마켓 상태 확인 (health 엔드포인트)
            try
            {
                var health = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/health");
                // US Eastern 시간 계산 (KST - 13h or 14h depending on DST)
                var kst = DateTime.Now;
                var etOffset = TimeZoneInfo.FindSystemTimeZoneById("America/New_York");
                var etNow = TimeZoneInfo.ConvertTime(kst, TimeZoneInfo.Local, etOffset);
                debugServerEt = etNow.ToString("yyyy-MM-dd HH:mm:ss ddd");
                var etHour = etNow.Hour * 60 + etNow.Minute;
                var isWeekday = etNow.DayOfWeek != DayOfWeek.Saturday && etNow.DayOfWeek != DayOfWeek.Sunday;
                debugMarketStatus = !isWeekday ? "CLOSED (Weekend)"
                    : etHour < 240 ? "CLOSED"      // ~04:00 전
                    : etHour < 570 ? "PRE"          // 04:00~09:30
                    : etHour < 960 ? "OPEN"         // 09:30~16:00
                    : etHour < 1200 ? "POST"        // 16:00~20:00
                    : "CLOSED";
            }
            catch { debugServerEt = "?"; debugMarketStatus = "?"; }

            StateHasChanged();

            // 각 워치리스트 종목별 chart API 호출
            var symbols = analysisResults
                .Select(r => r.TryGetProperty("symbol", out var sv) ? sv.GetString() ?? "" : "")
                .Where(s => !string.IsNullOrEmpty(s))
                .ToList();

            if (!symbols.Any())
            {
                symbols = watchlist.Select(w => w.Symbol).ToList();
            }

            foreach (var sym in symbols)
            {
                var sw = System.Diagnostics.Stopwatch.StartNew();
                try
                {
                    var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>(
                        $"/watchlist/chart/{sym}?period=1d");
                    sw.Stop();

                    var pts = resp.TryGetProperty("points", out var p) ? p : default;
                    var pointCount = pts.ValueKind == System.Text.Json.JsonValueKind.Array ? pts.GetArrayLength() : 0;
                    var dataDate = resp.TryGetProperty("data_date", out var dd) ? dd.GetString() : null;
                    var todayEt = resp.TryGetProperty("today_et", out var te) ? te.GetString() : null;
                    var prevClose = resp.TryGetProperty("prev_close", out var pc)
                        && pc.ValueKind == System.Text.Json.JsonValueKind.Number ? (double?)pc.GetDouble() : null;
                    var error = resp.TryGetProperty("error", out var er) ? er.GetString() : null;

                    string? firstTime = null, lastTime = null;
                    int preC = 0, regC = 0, postC = 0;
                    if (pointCount > 0)
                    {
                        var arr = pts.EnumerateArray().ToList();
                        firstTime = arr.First().TryGetProperty("time", out var ft) ? ft.GetString() : null;
                        lastTime = arr.Last().TryGetProperty("time", out var lt) ? lt.GetString() : null;
                        foreach (var pt in arr)
                        {
                            var sess = pt.TryGetProperty("session", out var ss) ? ss.GetString() : "";
                            if (sess == "pre") preC++;
                            else if (sess == "regular") regC++;
                            else if (sess == "post") postC++;
                        }
                    }

                    debugResults.Add(new ChartDebugResult(
                        sym, pointCount, dataDate, todayEt, prevClose,
                        firstTime, lastTime, preC, regC, postC,
                        sw.ElapsedMilliseconds, error));
                }
                catch (Exception ex)
                {
                    sw.Stop();
                    debugResults.Add(new ChartDebugResult(
                        sym, 0, null, null, null, null, null, 0, 0, 0,
                        sw.ElapsedMilliseconds, ex.Message));
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Debug error: {ex.Message}";
        }
        finally
        {
            debugRunning = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        _autoRefreshTimer?.Dispose();
    }
}
