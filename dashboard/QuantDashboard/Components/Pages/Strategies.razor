@page "/strategies"
@attribute [Authorize]
@inject PostgresService Db
@rendermode InteractiveServer

<PageTitle>Quant V3.1 - Strategies</PageTitle>

<div class="page-header">
    <h3>Strategy Performance</h3>
    <HelpTooltip Title="Strategy Performance"
                 Description="5개 전략의 성과 요약 및 시그널 현황" />
</div>

<!-- Strategy Overview Cards -->
<div class="stat-grid three-col">
    @foreach (var s in strategyInfo)
    {
        <div class="stat-card" style="border-left: 3px solid @s.Color">
            <span class="stat-label">@s.Name</span>
            <span class="stat-value" style="font-size: 1rem;">@s.Desc</span>
            <span class="stat-sub">Signals: @(signalCounts.GetValueOrDefault(s.Key, 0))</span>
        </div>
    }
</div>

<!-- Recent Signals -->
<div class="section-card">
    <h5>Recent Signals
        <HelpTooltip Title="Recent Signals"
                     Description="각 전략이 생성한 최근 매매 시그널 (LONG/SHORT)" />
    </h5>
    @if (signals.Any())
    {
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr><th>Time</th><th>Symbol</th><th>Strategy</th>
                        <th>Direction</th><th>Strength</th><th>Regime</th></tr>
                </thead>
                <tbody>
                    @foreach (var sig in signals.Take(50))
                    {
                        <tr>
                            <td>@sig.Time.ToString("MM-dd HH:mm")</td>
                            <td><SymbolLink Symbol="@sig.Symbol" Exchange="@(exchangeMap.GetValueOrDefault(sig.Symbol))" /></td>
                            <td>@sig.Strategy</td>
                            <td class="@(sig.Direction == "long" ? "text-green" : "text-red")">
                                @sig.Direction.ToUpper()
                            </td>
                            <td>
                                <div class="strength-bar">
                                    <div class="strength-fill @(sig.Strength > 0 ? "bull-bg" : "bear-bg")"
                                         style="width:@(Math.Abs(sig.Strength) * 100)%"></div>
                                </div>
                                <span>@(sig.Strength.ToString("F2"))</span>
                            </td>
                            <td class="regime-@sig.Regime">@sig.Regime</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No signals yet.</p>
    }
</div>

<!-- Strategy Performance History -->
<div class="section-card">
    <h5>Strategy Daily Performance (30d)
        <HelpTooltip Title="Strategy Daily Performance"
                     Description="전략별 일간 수익률, 배분 비율, 시그널 수" />
    </h5>
    @if (perf.Any())
    {
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr><th>Date</th><th>Strategy</th><th>Return</th>
                        <th>Allocation</th><th>Signals</th><th>Regime</th></tr>
                </thead>
                <tbody>
                    @foreach (var p in perf.Take(50))
                    {
                        <tr>
                            <td>@p.Time.ToString("yyyy-MM-dd")</td>
                            <td>@p.Strategy</td>
                            <td class="@(p.DailyReturn >= 0 ? "text-green" : "text-red")">
                                @(p.DailyReturn.ToString("P2"))
                            </td>
                            <td>@(p.Allocation.ToString("P0"))</td>
                            <td>@p.SignalCount</td>
                            <td class="regime-@p.Regime">@p.Regime</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No performance data yet. Run pipeline first.</p>
    }
</div>

@code {
    private List<SignalRecord> signals = new();
    private List<StrategyPerf> perf = new();
    private Dictionary<string, int> signalCounts = new();
    private Dictionary<string, string> exchangeMap = new();

    private static readonly List<(string Key, string Name, string Desc, string Color)> strategyInfo = new()
    {
        ("lowvol_quality", "Low-Vol + Quality", "Low volatility + ROE/FCF quality", "#22c55e"),
        ("vol_momentum", "Vol-Momentum", "12-1 momentum / realized vol", "#3b82f6"),
        ("pairs_trading", "Pairs Trading", "Cointegrated pairs mean-reversion", "#8b5cf6"),
    };

    protected override async Task OnInitializedAsync()
    {
        signals = await Db.GetRecentSignalsAsync(100);
        perf = await Db.GetStrategyPerfAsync(30);
        exchangeMap = await Db.GetSymbolExchangeMapAsync();

        signalCounts = signals
            .GroupBy(s => s.Strategy)
            .ToDictionary(g => g.Key, g => g.Count());
    }
}
