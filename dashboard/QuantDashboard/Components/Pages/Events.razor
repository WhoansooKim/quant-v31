@page "/events"
@attribute [Authorize]
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Swing V4 - Events</PageTitle>

<div class="page-header">
    <h3>Event Monitor</h3>
    <div style="display:flex; gap:0.5rem">
        <button class="btn-action" @onclick="ScanEvents" disabled="@scanning">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">radar</span>
            @(scanning ? "Scanning..." : "Scan Events")
        </button>
        <button class="btn-action" style="background:var(--accent-purple, #a78bfa)" @onclick="ScanEdgar" disabled="@scanningEdgar">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">description</span>
            @(scanningEdgar ? "Scanning..." : "SEC Filings")
        </button>
        <button class="btn-action btn-outline" @onclick="LoadEvents">
            <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle">refresh</span>
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMsg))
{
    <div class="alert-info" style="margin:0.5rem 0">@statusMsg</div>
}

<!-- Filter Tabs -->
<div class="tab-bar">
    @foreach (var tab in new[] { "all", "critical", "warning", "info" })
    {
        <button class="tab-btn @(activeFilter == tab ? "active" : "")"
                @onclick="() => SetFilter(tab)">
            @tab.ToUpper()
        </button>
    }
</div>

<!-- Events Table -->
<div class="section-card" style="margin-top:0.5rem">
    @if (events.Any())
    {
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:140px">Time</th>
                        <th>Severity</th>
                        <th>Type</th>
                        <th>Symbol</th>
                        <th>Title</th>
                        <th class="hide-mobile">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in PagedEvents)
                    {
                        var severity = e.GetValueOrDefault("severity", "info")?.ToString() ?? "info";
                        var evType = e.GetValueOrDefault("event_type", "")?.ToString() ?? "";
                        <tr class="@(severity == "critical" ? "row-critical" : severity == "warning" ? "row-warning" : "")">
                            <td class="text-muted">
                                @{
                                    var created = e.GetValueOrDefault("created_at");
                                    if (created is DateTime dt)
                                    {
                                        @dt.ToString("MM/dd HH:mm")
                                    }
                                    else if (created != null)
                                    {
                                        @created.ToString()!.Substring(5, 11)
                                    }
                                }
                            </td>
                            <td>
                                <span class="severity-chip severity-@severity">@severity</span>
                            </td>
                            <td class="text-muted">@evType.Replace("_", " ")</td>
                            <td style="font-weight:600">@(e.GetValueOrDefault("symbol") ?? "")</td>
                            <td>@(e.GetValueOrDefault("title") ?? "")</td>
                            <td class="hide-mobile">
                                @{
                                    var action = e.GetValueOrDefault("action_taken")?.ToString();
                                    if (!string.IsNullOrEmpty(action))
                                    {
                                        <span class="action-chip">@action</span>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        @if (evtTotalPages > 1)
        {
            <div class="pagination-bar">
                <button class="btn-page" disabled="@(evtCurrentPage <= 1)" @onclick="() => GoToEvtPage(1)">«</button>
                <button class="btn-page" disabled="@(evtCurrentPage <= 1)" @onclick="() => GoToEvtPage(evtCurrentPage - 1)">‹</button>
                @for (int pg = evtPageStart; pg <= evtPageEnd; pg++)
                {
                    var p = pg;
                    <button class="btn-page @(p == evtCurrentPage ? "btn-page-active" : "")" @onclick="() => GoToEvtPage(p)">@p</button>
                }
                <button class="btn-page" disabled="@(evtCurrentPage >= evtTotalPages)" @onclick="() => GoToEvtPage(evtCurrentPage + 1)">›</button>
                <button class="btn-page" disabled="@(evtCurrentPage >= evtTotalPages)" @onclick="() => GoToEvtPage(evtTotalPages)">»</button>
                <span class="text-muted" style="font-size:0.72rem; margin-left:0.5rem">@events.Count events</span>
            </div>
        }
    }
    else
    {
        <p class="text-muted" style="padding:1rem">No events found. Click "Scan Events" to check for new events.</p>
    }
</div>

@code {
    private List<Dictionary<string, object?>> events = new();
    private string activeFilter = "all";
    private bool scanning;
    private bool scanningEdgar;
    private string? statusMsg;

    // Pagination (client-side — events loaded from engine API)
    private const int EvtPageSize = 10;
    private int evtCurrentPage = 1;
    private int evtTotalPages => Math.Max(1, (int)Math.Ceiling((double)events.Count / EvtPageSize));
    private int evtPageStart => Math.Max(1, evtCurrentPage - 2);
    private int evtPageEnd => Math.Min(evtTotalPages, evtPageStart + 4);

    private IEnumerable<Dictionary<string, object?>> PagedEvents =>
        events.Skip((evtCurrentPage - 1) * EvtPageSize).Take(EvtPageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private void GoToEvtPage(int pg)
    {
        if (pg < 1 || pg > evtTotalPages || pg == evtCurrentPage) return;
        evtCurrentPage = pg;
    }

    private async Task LoadEvents()
    {
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var severity = activeFilter == "all" ? "" : $"&severity={activeFilter}";
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>(
                $"/events?limit=100{severity}");
            events.Clear();
            if (resp.TryGetProperty("events", out var arr))
            {
                foreach (var item in arr.EnumerateArray())
                {
                    var dict = new Dictionary<string, object?>();
                    foreach (var prop in item.EnumerateObject())
                    {
                        dict[prop.Name] = prop.Value.ValueKind switch
                        {
                            System.Text.Json.JsonValueKind.String => prop.Value.GetString(),
                            System.Text.Json.JsonValueKind.Number => prop.Value.GetDouble(),
                            System.Text.Json.JsonValueKind.True => true,
                            System.Text.Json.JsonValueKind.False => false,
                            _ => prop.Value.ToString()
                        };
                    }
                    events.Add(dict);
                }
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Load error: {ex.Message}";
        }
    }

    private async Task ScanEvents()
    {
        scanning = true;
        statusMsg = null;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/events/scan", null);
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                var found = json.TryGetProperty("events_found", out var f) ? f.GetInt32() : 0;
                statusMsg = $"Scan completed: {found} events detected";
                await LoadEvents();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                statusMsg = $"Scan failed: {body}";
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            scanning = false;
        }
    }

    private async Task ScanEdgar()
    {
        scanningEdgar = true;
        statusMsg = null;
        StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.PostAsync("/events/edgar-scan", null);
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                var found = json.TryGetProperty("events_found", out var f) ? f.GetInt32() : 0;
                statusMsg = $"EDGAR scan: {found} SEC filings detected";
                await LoadEvents();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                statusMsg = $"EDGAR scan failed: {body}";
            }
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally
        {
            scanningEdgar = false;
        }
    }

    private async Task SetFilter(string filter)
    {
        activeFilter = filter;
        evtCurrentPage = 1;
        await LoadEvents();
    }
}
