@page "/"
@attribute [Authorize]
@inject SwingService Db
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Swing V4 - Home</PageTitle>

<div class="page-header">
    <h3>Portfolio Overview</h3>
    <span class="text-muted" style="font-size:0.7rem">
        @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
    </span>
</div>

<!-- 4 KPI Cards -->
<div class="stat-grid cols-4">
    <div class="stat-card">
        <span class="stat-label">Total Value</span>
        <span class="stat-value">
            @if (snapshot != null && snapshot.TotalValueUsd.HasValue)
            {
                @($"${snapshot.TotalValueUsd:N2}")
            }
            else
            {
                <span>$2,200.00</span>
            }
        </span>
        @if (snapshot?.TotalValueKrw != null)
        {
            <span class="stat-sub">&#8361;@($"{snapshot.TotalValueKrw:N0}")</span>
        }
    </div>

    <div class="stat-card">
        <span class="stat-label">Daily P&L</span>
        <span class="stat-value @(dailyPnl >= 0 ? "text-green" : "text-red")">
            @(dailyPnl >= 0 ? "+" : "")$@($"{dailyPnl:N2}")
        </span>
        @if (snapshot?.DailyReturn != null)
        {
            <span class="stat-sub @(snapshot.DailyReturn >= 0 ? "text-green" : "text-red")">
                @(snapshot.DailyReturn >= 0 ? "+" : "")@($"{snapshot.DailyReturn * 100:F2}")%
            </span>
        }
    </div>

    <div class="stat-card">
        <span class="stat-label">Cumulative Return</span>
        <span class="stat-value @(cumReturn >= 0 ? "text-green" : "text-red")">
            @(cumReturn >= 0 ? "+" : "")@($"{cumReturn * 100:F2}")%
        </span>
    </div>

    <div class="stat-card">
        <span class="stat-label">Positions</span>
        <span class="stat-value">@openPositions.Count / 4</span>
        @if (pendingSignals > 0)
        {
            <span class="stat-sub" style="color:var(--sideways)">@pendingSignals pending</span>
        }
    </div>
</div>

<!-- Backtest Projection -->
@if (latestBt != null)
{
    <div class="section-card" style="margin-top:0rem; margin-bottom:1rem">
        <h4 class="section-title">Backtest Projection
            <span class="text-muted" style="font-size:0.72rem; font-weight:400; margin-left:auto">
                @latestBt.StartDate.ToString("yy/MM") - @latestBt.EndDate.ToString("yy/MM")
            </span>
        </h4>
        <div class="stat-grid cols-4">
            <div class="stat-card">
                <span class="stat-label">CAGR</span>
                <span class="stat-value @((latestBt.Cagr ?? 0) >= 0 ? "text-green" : "text-red")">
                    @($"{(latestBt.Cagr ?? 0) * 100:F1}")%
                </span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Total Return</span>
                <span class="stat-value @((latestBt.TotalReturn ?? 0) >= 0 ? "text-green" : "text-red")">
                    @($"{(latestBt.TotalReturn ?? 0) * 100:F1}")%
                </span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Sharpe</span>
                <span class="stat-value">@($"{latestBt.SharpeRatio:F2}")</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Max Drawdown</span>
                <span class="stat-value text-red">@($"{(latestBt.MaxDrawdown ?? 0) * 100:F1}")%</span>
            </div>
        </div>
        <a href="/backtest" class="bt-projection-link">
            View full backtest →
        </a>
    </div>
}
else
{
    <div class="section-card" style="margin-top:0rem; margin-bottom:1rem">
        <h4 class="section-title">Backtest Projection</h4>
        <p class="text-muted" style="font-size:0.85rem">
            No backtest data yet. <a href="/backtest" class="bt-projection-link">Run a backtest</a> to see projected performance.
        </p>
    </div>
}

<!-- Open Positions Table -->
<div class="section-card" style="margin-top:1rem">
    <h4 class="section-title">Open Positions</h4>
    @if (openPositions.Any())
    {
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Symbol</th>
                        <th>Qty</th>
                        <th>Entry</th>
                        <th>Current</th>
                        <th>P&L</th>
                        <th>P&L %</th>
                        <th>SL / TP</th>
                        <th>Days</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in openPositions)
                    {
                        var pnlClass = (p.UnrealizedPct ?? 0) >= 0 ? "text-green" : "text-red";
                        var holdDays = (DateTime.Now - p.EntryTime).Days;
                        <tr>
                            <td><SymbolLink Symbol="@p.Symbol" OnSymbolClick="OpenModal" /></td>
                            <td>@p.Qty</td>
                            <td>$@p.EntryPrice.ToString("F2")</td>
                            <td>@(p.CurrentPrice != null ? $"${p.CurrentPrice:F2}" : "--")</td>
                            <td class="@pnlClass">
                                @(p.UnrealizedPnl != null ? $"{(p.UnrealizedPnl >= 0 ? "+" : "")}${p.UnrealizedPnl:F2}" : "--")
                            </td>
                            <td class="@pnlClass">
                                @(p.UnrealizedPct != null ? $"{(p.UnrealizedPct >= 0 ? "+" : "")}{p.UnrealizedPct * 100:F2}%" : "--")
                            </td>
                            <td>
                                <span class="text-red">@(p.StopLoss != null ? $"${p.StopLoss:F2}" : "--")</span>
                                /
                                <span class="text-green">@(p.TakeProfit != null ? $"${p.TakeProfit:F2}" : "--")</span>
                            </td>
                            <td>@holdDays</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No open positions</p>
    }
</div>

<!-- Equity Curve Chart -->
<div class="section-card" style="margin-top:1rem">
    <h4 class="section-title">Equity Curve</h4>
    <div style="height:250px">
        <canvas id="equityCurveChart"></canvas>
    </div>
</div>

<!-- Recent Activity -->
<div class="section-card" style="margin-top:1rem">
    <h4 class="section-title">Recent Activity</h4>
    @if (recentTrades.Any())
    {
        @foreach (var t in recentTrades.Take(5))
        {
            var cls = t.Side == "BUY" ? "text-green" : "text-red";
            <div class="activity-item">
                <span class="@cls" style="font-weight:600">@(t.Side == "BUY" ? "+" : "-") @t.Symbol</span>
                <span>@t.Qty shares @@ $@t.Price.ToString("F2")</span>
                <span class="text-muted">@t.ExecutedAt.ToString("MM/dd HH:mm")</span>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No recent trades</p>
    }
</div>

<SymbolDetailModal Visible="@modalVisible" Symbol="@modalSymbol" OnClose="CloseModal" />

@code {
    private SwingSnapshot? snapshot;
    private List<SwingPosition> openPositions = new();
    private List<SwingTrade> recentTrades = new();
    private List<SwingSnapshot> snapHistory = new();
    private SwingBacktestRun? latestBt;
    private int pendingSignals;
    private decimal dailyPnl;
    private double cumReturn;

    // Modal state
    private bool modalVisible;
    private string modalSymbol = "";

    private void OpenModal(string symbol) { modalSymbol = symbol; modalVisible = true; }
    private void CloseModal() { modalVisible = false; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var snapTask = Db.GetLatestSnapshotAsync();
            var posTask = Db.GetOpenPositionsAsync();
            var tradeTask = Db.GetRecentTradesAsync(5);
            var histTask = Db.GetSnapshotHistoryAsync(30);
            var sigTask = Db.GetPendingSignalCountAsync();
            var btTask = Db.GetLatestBacktestRunAsync();

            await Task.WhenAll(snapTask, posTask, tradeTask, histTask, sigTask, btTask);

            snapshot = snapTask.Result;
            openPositions = posTask.Result;
            recentTrades = tradeTask.Result;
            snapHistory = histTask.Result;
            pendingSignals = sigTask.Result;
            latestBt = btTask.Result;

            dailyPnl = snapshot?.DailyPnlUsd ?? 0;
            cumReturn = snapshot?.CumulativeReturn ?? 0;
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && snapHistory.Any())
        {
            try
            {
                var labels = snapHistory.Select(s => s.Time.ToString("MM/dd")).ToArray();
                var values = snapHistory.Select(s => (double)(s.TotalValueUsd ?? 0)).ToArray();
                var datasets = new[]
                {
                    new {
                        label = "Portfolio Value ($)",
                        data = values,
                        borderColor = "#197fe6",
                        backgroundColor = "rgba(25,127,230,0.08)",
                        fill = true,
                        tension = 0.3,
                        pointRadius = 0,
                        borderWidth = 2
                    }
                };
                await JS.InvokeVoidAsync("chartHelper.createLine",
                    "equityCurveChart", labels, datasets, (object?)null);
            }
            catch { }
        }
    }
}
