    // ─── Daily ───
    private async Task LoadDailyList()
    {
        busy = true; StateHasChanged();
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/analysis/daily?limit=30");
            dailyList = new();
            if (resp.TryGetProperty("reports", out var arr))
            {
                foreach (var item in arr.EnumerateArray())
                {
                    var dict = new Dictionary<string, object?>();
                    foreach (var prop in item.EnumerateObject())
                    {
                        dict[prop.Name] = prop.Value.ValueKind switch
                        {
                            System.Text.Json.JsonValueKind.String => prop.Value.GetString(),
                            System.Text.Json.JsonValueKind.Number => prop.Value.GetDouble(),
                            System.Text.Json.JsonValueKind.Null => null,
                            _ => prop.Value.ToString()
                        };
                    }
                    dailyList.Add(dict);
                }
            }
        }
        catch (Exception ex) { statusMsg = $"Daily list error: {ex.Message}"; }
        finally { busy = false; }
    }
    private async Task LoadDailyDetail(string dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return;
        var d = dateStr.Length >= 10 ? dateStr.Substring(0, 10) : dateStr;
        try
        {
            var client = HttpFactory.CreateClient("Engine");
            selectedDaily = await client.GetFromJsonAsync<System.Text.Json.JsonElement>($"/analysis/daily/{d}");
        }
        catch (Exception ex) { statusMsg = $"Daily detail error: {ex.Message}"; }
    }
