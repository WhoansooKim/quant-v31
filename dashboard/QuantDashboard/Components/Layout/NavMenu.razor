<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <span class="brand-icon">S</span> Swing V4
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">

    <AuthorizeView>
        <Authorized>
            <div class="nav-user-section">
                <span class="nav-user-avatar">@(context.User.Identity?.Name?[..1].ToUpper())</span>
                <span class="nav-user-name">@context.User.Identity?.Name</span>
                <form method="post" action="/account/logout">
                    <button type="submit" class="nav-user-logout">Logout</button>
                </form>
            </div>
        </Authorized>
    </AuthorizeView>

    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="material-symbols-outlined nav-icon">dashboard</span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pipeline">
                <span class="material-symbols-outlined nav-icon">conversion_path</span> Pipeline
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="signals">
                <span class="material-symbols-outlined nav-icon">notifications_active</span> Signals
                @if (_pendingCount > 0)
                {
                    <span class="nav-badge">@_pendingCount</span>
                }
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="performance">
                <span class="material-symbols-outlined nav-icon">monitoring</span> Performance
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="positions">
                <span class="material-symbols-outlined nav-icon">account_balance_wallet</span> Positions
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="backtest">
                <span class="material-symbols-outlined nav-icon">query_stats</span> Backtest
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="events">
                <span class="material-symbols-outlined nav-icon">bolt</span> Events
            </NavLink>
        </div>

        <div class="nav-divider"></div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="settings">
                <span class="material-symbols-outlined nav-icon">settings</span> Settings
            </NavLink>
        </div>
    </nav>
</div>

@code {
    [Inject] private SwingService? SwingSvc { get; set; }
    private int _pendingCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (SwingSvc != null)
                _pendingCount = await SwingSvc.GetPendingSignalCountAsync();
        }
        catch { }
    }
}
