@inherits LayoutComponentBase
@using System.Security.Claims

<div class="page dark-theme">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-bar">
            <AuthorizeView>
                <Authorized>
                    <div class="top-bar-user">
                        <span class="user-avatar">@(context.User.Identity?.Name?[..1].ToUpper())</span>
                        <span class="user-name">@context.User.Identity?.Name</span>
                    </div>
                    <form method="post" action="/account/logout">
                        <button type="submit" class="top-bar-logout">Sign Out</button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4 py-3">
            @Body
        </article>

        <footer class="app-footer">
            Quant V3.1 Ubuntu Edition | HMM Regime + Kill Switch + FinBERT
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">X</a>
</div>
