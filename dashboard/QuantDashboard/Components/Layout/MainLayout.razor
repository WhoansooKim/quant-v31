@inherits LayoutComponentBase
@inject SwingService SwingSvc
@inject IHttpClientFactory HttpFactory

<!-- Mobile Top Bar -->
<div class="mobile-topbar">
    <span class="brand-icon">S</span>
    <span class="brand-text">Swing V4</span>
    <button class="mobile-menu-btn" onclick="toggleMobileSidebar()">
        <span class="material-symbols-outlined">menu</span>
    </button>
</div>

<!-- Mobile Sidebar Overlay -->
<div class="mobile-sidebar-overlay" id="mobile-sidebar-overlay" onclick="closeMobileSidebar(event)">
    <div class="sidebar" onclick="event.stopPropagation()">
        <NavMenu />
    </div>
</div>

<div class="page dark-theme" id="page-root">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <!-- Ticker Bar -->
        <div class="ticker-bar">
            @if (tickerData.Any())
            {
                @foreach (var t in tickerData)
                {
                    <div class="ticker-item">
                        <span class="ticker-symbol">@t.Symbol</span>
                        <span class="ticker-price">@t.Price.ToString("F2")</span>
                        <span class="ticker-change @(t.ChangePercent >= 0 ? "ticker-up" : "ticker-down")">
                            @(t.ChangePercent >= 0 ? "+" : "")@t.ChangePercent.ToString("F2")%
                        </span>
                    </div>
                }
            }
            else
            {
                <span class="text-muted" style="font-size:0.72rem">No open positions to track</span>
            }
        </div>

        <article class="content">
            <ErrorBoundary @ref="errorBoundary">
                <ChildContent>@Body</ChildContent>
                <ErrorContent Context="_">
                    @{ RecoverSilently(); }
                    @Body
                </ErrorContent>
            </ErrorBoundary>
        </article>

        <footer class="app-footer">
            Swing V4 &mdash; Semi-Auto Swing Trading System
        </footer>
    </main>
</div>

<!-- SSE Toast Notifications (Interactive Component) -->
<SseToastPanel />

<!-- Silent reconnect/error handlers (화면에 표시되지 않음) -->
<div id="blazor-reconnect-modal" style="display:none"></div>
<div id="blazor-error-ui" style="display:none"></div>

@code {
    private List<TickerBarItem> tickerData = new();
    private ErrorBoundary? errorBoundary;
    private static List<TickerBarItem>? _cachedTickers;
    private static DateTime _cacheExpiry = DateTime.MinValue;

    private void RecoverSilently()
    {
        _ = Task.Run(async () =>
        {
            await Task.Delay(100);
            await InvokeAsync(() => errorBoundary?.Recover());
        });
    }

    protected override void OnInitialized()
    {
        // 캐시된 데이터가 있으면 즉시 표시 (페이지 전환 차단 없음)
        if (_cachedTickers != null && DateTime.UtcNow < _cacheExpiry)
        {
            tickerData = _cachedTickers;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // 캐시 만료 시에만 백그라운드로 갱신 (60초 TTL)
        if (_cachedTickers == null || DateTime.UtcNow >= _cacheExpiry)
        {
            try
            {
                var client = HttpFactory.CreateClient("Engine");
                using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(5));
                var resp = await client.GetFromJsonAsync<System.Text.Json.JsonElement>("/ticker", cts.Token);
                if (resp.TryGetProperty("tickers", out var arr))
                {
                    var newData = arr.EnumerateArray().Select(t => new TickerBarItem(
                        Symbol: t.GetProperty("symbol").GetString() ?? "",
                        Price: t.GetProperty("price").GetDouble(),
                        ChangePercent: t.GetProperty("change_pct").GetDouble()
                    )).ToList();

                    _cachedTickers = newData;
                    _cacheExpiry = DateTime.UtcNow.AddSeconds(60);
                    tickerData = newData;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { /* silent — 이전 캐시 유지 */ }
        }
    }
}
