@inherits LayoutComponentBase
@inject SwingService SwingSvc

<div class="page dark-theme">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <!-- Ticker Bar -->
        <div class="ticker-bar">
            @if (tickerData.Any())
            {
                @foreach (var t in tickerData)
                {
                    <div class="ticker-item">
                        <span class="ticker-symbol">@t.Symbol</span>
                        <span class="ticker-price">@t.Price.ToString("F2")</span>
                        <span class="ticker-change @(t.ChangePercent >= 0 ? "ticker-up" : "ticker-down")">
                            @(t.ChangePercent >= 0 ? "+" : "")@t.ChangePercent.ToString("F2")%
                        </span>
                    </div>
                }
            }
            else
            {
                <span class="text-muted" style="font-size:0.72rem">SPY -- | QQQ -- | AAPL -- | MSFT -- | NVDA --</span>
            }
        </div>

        <article class="content">
            @Body
        </article>

        <footer class="app-footer">
            Swing V4 &mdash; Semi-Auto Swing Trading System
        </footer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">X</a>
</div>

@code {
    private List<TickerBarItem> tickerData = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            tickerData = await SwingSvc.GetTickerBarDataAsync();
        }
        catch
        {
            tickerData = new();
        }
    }
}
