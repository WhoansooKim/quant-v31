<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="QuantDashboard.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body class="dark-theme">
    <Routes />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2"></script>
    <script src="js/charts.js"></script>
    <script>
        function toggleSidebar() {
            var page = document.getElementById('page-root');
            if (!page) return;
            page.classList.toggle('sidebar-collapsed');
            var collapsed = page.classList.contains('sidebar-collapsed');
            localStorage.setItem('sidebar-collapsed', collapsed ? '1' : '');
            var icon = document.querySelector('.sidebar-toggle-icon');
            if (icon) icon.textContent = collapsed ? 'menu' : 'menu_open';
        }
        // 페이지 로드 시 저장된 상태 복원
        (function() {
            if (localStorage.getItem('sidebar-collapsed') === '1') {
                document.documentElement.classList.add('sidebar-init-collapsed');
            }
        })();
        document.addEventListener('DOMContentLoaded', function() {
            if (localStorage.getItem('sidebar-collapsed') === '1') {
                var page = document.getElementById('page-root');
                if (page) page.classList.add('sidebar-collapsed');
                var icon = document.querySelector('.sidebar-toggle-icon');
                if (icon) icon.textContent = 'menu';
            }
        });
        // Help 페이지: 지표 설명 아코디언 토글
        function toggleIndicator(id) {
            var body = document.getElementById('ind-' + id + '-body');
            var icon = document.getElementById('ind-' + id + '-icon');
            if (!body) return;
            var open = body.style.display !== 'none';
            body.style.display = open ? 'none' : 'block';
            if (icon) icon.textContent = open ? '\u25b6' : '\u25bc';
        }
        function openIndicatorPopup(id) {
            toggleIndicator(id);
            var el = document.getElementById('ind-' + id);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        // Help 페이지: 섹션 아코디언 토글
        function toggleHelpSection(id) {
            var body = document.getElementById('help-body-' + id);
            var icon = document.getElementById('help-icon-' + id);
            if (!body) return;
            var open = body.style.display !== 'none';
            body.style.display = open ? 'none' : 'block';
            if (icon) icon.textContent = open ? '\u25b6' : '\u25bc';
        }
        // Help 페이지: 초기 로드 시 모든 섹션 접기
        function initHelpCollapsed() {
            for (var i = 1; i <= 20; i++) {
                var body = document.getElementById('help-body-' + i);
                var icon = document.getElementById('help-icon-' + i);
                if (body) { body.style.display = 'none'; }
                if (icon) { icon.textContent = '\u25b6'; }
            }
        }
        // Mobile sidebar toggle
        function toggleMobileSidebar() {
            var overlay = document.getElementById('mobile-sidebar-overlay');
            if (overlay) overlay.classList.toggle('open');
        }
        function closeMobileSidebar(e) {
            var overlay = document.getElementById('mobile-sidebar-overlay');
            if (overlay && (e.target === overlay)) overlay.classList.remove('open');
        }
        // Close mobile sidebar on nav link click
        document.addEventListener('click', function(e) {
            if (e.target.closest && e.target.closest('.mobile-sidebar-overlay .nav-link')) {
                var overlay = document.getElementById('mobile-sidebar-overlay');
                if (overlay) overlay.classList.remove('open');
            }
        });
        // Enhanced Blazor navigation 후에도 복원
        var _sidebarObserver = new MutationObserver(function() {
            var page = document.getElementById('page-root');
            if (page && localStorage.getItem('sidebar-collapsed') === '1' && !page.classList.contains('sidebar-collapsed')) {
                page.classList.add('sidebar-collapsed');
                var icon = document.querySelector('.sidebar-toggle-icon');
                if (icon) icon.textContent = 'menu';
            }
        });
        document.addEventListener('DOMContentLoaded', function() {
            _sidebarObserver.observe(document.body, { childList: true, subtree: true });
        });
    </script>
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        // Silent auto-reconnect: 끊기면 재연결 시도 → 실패 시 조용히 페이지 리로드
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 12,
                    retryIntervalMilliseconds: (attempt) => {
                        // 1초 → 2초 → 3초 → 5초 (빠르게 재연결 시도)
                        const intervals = [1000, 1000, 2000, 2000, 3000, 3000, 5000, 5000, 5000, 5000, 5000, 5000];
                        return intervals[Math.min(attempt, intervals.length - 1)];
                    },
                    dialogId: 'blazor-reconnect-modal'
                }
            }
        });

        // 재연결 실패/거부 시 조용히 리로드
        new MutationObserver((mutations) => {
            const modal = document.getElementById('blazor-reconnect-modal');
            if (!modal) return;
            const cls = modal.className;
            if (cls.includes('components-reconnect-failed') || cls.includes('components-reconnect-rejected')) {
                location.reload();
            }
        }).observe(document.getElementById('blazor-reconnect-modal'), { attributes: true, attributeFilter: ['class'] });

        // unhandled error 발생 시 3초 후 조용히 리로드
        new MutationObserver(() => {
            const el = document.getElementById('blazor-error-ui');
            if (el && getComputedStyle(el).display !== 'none') {
                setTimeout(() => location.reload(), 2000);
            }
        }).observe(document.getElementById('blazor-error-ui'), { attributes: true, attributeFilter: ['style'] });
    </script>
</body>

</html>
