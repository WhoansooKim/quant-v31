@implements IDisposable
@inject IHttpClientFactory HttpFactory
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="toast-container">
    @foreach (var t in toasts)
    {
        <div class="toast-item toast-@t.Severity @(t.FadingOut ? "fade-out" : "")">
            <div class="toast-header">
                <span class="toast-icon material-symbols-outlined">
                    @(t.Severity == "critical" ? "error" : t.Severity == "warning" ? "warning" : t.Severity == "success" ? "check_circle" : "info")
                </span>
                <strong>@t.Title</strong>
                <button class="toast-close" @onclick="() => RemoveToast(t)">X</button>
            </div>
            @if (!string.IsNullOrEmpty(t.Message))
            {
                <div class="toast-body">@t.Message</div>
            }
        </div>
    }
</div>

@code {
    private List<ToastItem> toasts = new();
    private CancellationTokenSource? cts;
    private int nextId = 0;
    private bool disposed;

    protected override void OnInitialized()
    {
        cts = new CancellationTokenSource();
        _ = ListenSseAsync(cts.Token);
    }

    private async Task ListenSseAsync(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                var client = HttpFactory.CreateClient("Engine");
                using var request = new HttpRequestMessage(HttpMethod.Get, "/events/stream");
                request.Headers.Accept.Add(new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("text/event-stream"));
                using var response = await client.SendAsync(request, HttpCompletionOption.ResponseHeadersRead, token);
                using var stream = await response.Content.ReadAsStreamAsync(token);
                using var reader = new System.IO.StreamReader(stream);

                while (!token.IsCancellationRequested)
                {
                    var line = await reader.ReadLineAsync(token);
                    if (line == null) break;
                    if (!line.StartsWith("data: ")) continue;

                    var json = line.Substring(6);
                    try
                    {
                        var evt = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(json);
                        var type = evt.TryGetProperty("type", out var t) ? t.GetString() : "";
                        if (type == "heartbeat" || type == "connected") continue;

                        var title = type switch
                        {
                            "trade_executed" => "Trade Executed",
                            "event_scanned" => "Events Scanned",
                            "mode_changed" => "Mode Changed",
                            _ => "Notification"
                        };
                        var message = evt.TryGetProperty("message", out var m) ? m.GetString() ?? "" : "";
                        var severity = evt.TryGetProperty("severity", out var s) ? s.GetString() ?? "info" : "info";

                        if (disposed) return;
                        await InvokeAsync(() =>
                        {
                            if (disposed) return;
                            AddToast(title, message, severity);
                            StateHasChanged();
                        });
                    }
                    catch { }
                }
            }
            catch (OperationCanceledException) { break; }
            catch (ObjectDisposedException) { break; }
            catch
            {
                if (disposed) break;
                try { await Task.Delay(5000, token); } catch { break; }
            }
        }
    }

    private void AddToast(string title, string message, string severity)
    {
        var toast = new ToastItem
        {
            Id = nextId++,
            Title = title,
            Message = message,
            Severity = severity
        };
        toasts.Add(toast);
        _ = AutoRemoveAsync(toast);
    }

    private async Task AutoRemoveAsync(ToastItem toast)
    {
        try
        {
            await Task.Delay(4000);
            if (disposed) return;
            await InvokeAsync(() =>
            {
                if (disposed) return;
                toast.FadingOut = true;
                StateHasChanged();
            });
            await Task.Delay(500);
            if (disposed) return;
            await InvokeAsync(() =>
            {
                if (disposed) return;
                toasts.Remove(toast);
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
    }

    private void RemoveToast(ToastItem toast)
    {
        toasts.Remove(toast);
    }

    public void Dispose()
    {
        disposed = true;
        cts?.Cancel();
        cts?.Dispose();
    }

    private class ToastItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Severity { get; set; } = "info";
        public bool FadingOut { get; set; }
    }
}
